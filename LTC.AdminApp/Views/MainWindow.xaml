<Window x:Class="LTC.AdminApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Limitless Trade Copier — Admin"
        Icon="/Assets/ltc-icon.ico"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontUi}"
        FontSize="12"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <!--
        Admin app shell with four sidebar tabs: Mint, Fingerprint, Settings, About.
        Visual differences vs the customer app:
          1. ADMIN red pill next to the brand mark
          2. No live trading stats in the top bar
    -->
    <Window.Resources>
        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="6,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Wrap" CornerRadius="6" Padding="10,9"
                                Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding Tag}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           VerticalAlignment="Center" />
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Wrap" Property="Background"
                                        Value="{DynamicResource BorderSubtleBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Wrap" Property="Background"
                                        Value="{DynamicResource BgRaisedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgVoidBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="34" Height="18" Margin="0,0,10,0">
                        <Ellipse Width="14" Height="14" Fill="{DynamicResource MasterBrush}"
                                 HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <Ellipse Width="14" Height="14" Fill="{DynamicResource SlaveBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                        <Rectangle Width="5" Height="14" Fill="{DynamicResource BrandBrush}"
                                   RadiusX="2.5" RadiusY="2.5"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="LIMITLESS"
                               FontFamily="{StaticResource FontDisplay}" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#7F1D1D"
                        CornerRadius="3"
                        Padding="8,3"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="ADMIN"
                               FontFamily="{StaticResource FontMono}" FontSize="9"
                               FontWeight="Bold"
                               Foreground="#FCA5A5" />
                </Border>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MACHINE"
                               FontFamily="{StaticResource FontMono}" FontSize="8"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextDimBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock x:Name="OperatorMachineText"
                               Text="—"
                               FontFamily="{StaticResource FontMono}" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource BgVoidBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="WORKSPACE"
                               FontFamily="{StaticResource FontMono}" FontSize="9"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextDimBrush}"
                               Margin="18,0,0,8" />
                    <RadioButton x:Name="NavMint" Style="{StaticResource NavItem}"
                                 IsChecked="True" GroupName="Nav" Tag="◉"
                                 Checked="OnNavMintChecked">
                        <TextBlock Text="Mint license" Style="{StaticResource NavLabel}" />
                    </RadioButton>
                    <RadioButton x:Name="NavFingerprint" Style="{StaticResource NavItem}"
                                 GroupName="Nav" Tag="⌂"
                                 Checked="OnNavFingerprintChecked">
                        <TextBlock Text="Fingerprint" Style="{StaticResource NavLabel}" />
                    </RadioButton>
                    <RadioButton x:Name="NavSettings" Style="{StaticResource NavItem}"
                                 GroupName="Nav" Tag="⚙"
                                 Checked="OnNavSettingsChecked">
                        <TextBlock Text="Settings" Style="{StaticResource NavLabel}" />
                    </RadioButton>
                    <RadioButton x:Name="NavAbout" Style="{StaticResource NavItem}"
                                 GroupName="Nav" Tag="?"
                                 Checked="OnNavAboutChecked">
                        <TextBlock Text="About" Style="{StaticResource NavLabel}" />
                    </RadioButton>

                    <TextBlock Text="COMING SOON"
                               FontFamily="{StaticResource FontMono}" FontSize="9"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextFaintBrush}"
                               Margin="20,30,0,8" />
                    <TextBlock Text="·  Licenses log"
                               FontSize="11"
                               Foreground="{DynamicResource TextFaintBrush}"
                               Margin="20,2,0,2" />
                    <TextBlock Text="·  Revoke / list keys"
                               FontSize="11"
                               Foreground="{DynamicResource TextFaintBrush}"
                               Margin="20,2,0,2" />
                    <TextBlock Text="·  Stripe webhook"
                               FontSize="11"
                               Foreground="{DynamicResource TextFaintBrush}"
                               Margin="20,2,0,2" />
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Background="{DynamicResource BgBaseBrush}">
                <ContentControl x:Name="TabMintHost" Visibility="Visible" />
                <ContentControl x:Name="TabFingerprintHost" Visibility="Collapsed" />
                <ContentControl x:Name="TabSettingsHost" Visibility="Collapsed" />
                <ContentControl x:Name="TabAboutHost" Visibility="Collapsed" />
            </Grid>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgVoidBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="ready"
                           FontFamily="{StaticResource FontMono}" FontSize="10"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextDimBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="v0.2 admin"
                           FontFamily="{StaticResource FontMono}" FontSize="10"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextFaintBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
