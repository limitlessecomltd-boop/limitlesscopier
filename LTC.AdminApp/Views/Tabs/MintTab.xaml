<UserControl x:Class="LTC.AdminApp.Views.Tabs.MintTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Mint tab — the daily-use form. Layout:
          - Page title + intro line
          - Form panel: Email / Plan / Fingerprint / Expiry / Output path
          - Mint button bottom-right
          - Result panel slides in below the form when minting succeeds,
            showing license key + buttons (Reveal in Explorer / Copy details)

        The form is a single ScrollViewer in case the window is short.
    -->
    <Grid Background="{DynamicResource BgBaseBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="32,24,32,24">
            <StackPanel MaxWidth="780" HorizontalAlignment="Left">

                <!-- Page header -->
                <TextBlock Text="MINT LICENSE"
                           FontFamily="{StaticResource FontDisplay}" FontSize="28"
                           Foreground="{DynamicResource TextStrongBrush}"
                           LineHeight="28" />
                <TextBlock Text="Issue a hardware-bound license file for a paying customer."
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,28" />

                <!-- =====================================================
                     FORM PANEL
                     ===================================================== -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="22,18">
                    <StackPanel>

                        <!-- Email -->
                        <TextBlock Text="CUSTOMER EMAIL"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="EmailBox"
                                 FontFamily="{StaticResource FontUi}" FontSize="13"
                                 Padding="10,8"
                                 Background="{DynamicResource BgRaisedBrush}"
                                 BorderBrush="{DynamicResource BorderSubtleBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource BrandBrush}" />
                        <TextBlock Text="The email shown in the customer's Settings → License."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Margin="2,4,0,16" />

                        <!-- Plan -->
                        <TextBlock Text="PLAN"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox x:Name="PlanBox"
                                  FontFamily="{StaticResource FontUi}" FontSize="13"
                                  Padding="10,6"
                                  Background="{DynamicResource BgRaisedBrush}"
                                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  SelectedIndex="0"
                                  SelectionChanged="OnPlanSelectionChanged">
                            <ComboBoxItem Content="Lifetime" />
                            <ComboBoxItem Content="Daily" />
                            <ComboBoxItem Content="Partner" />
                            <ComboBoxItem Content="Dev" />
                        </ComboBox>
                        <TextBlock Text="Lifetime = no expiry. Daily = enter days below. Partner/Dev are no-expiry internal tiers."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Margin="2,4,0,16" />

                        <!-- Expiry days (only relevant for Daily) -->
                        <Grid x:Name="ExpiryRow">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="EXPIRES IN (DAYS)"
                                           FontFamily="{StaticResource FontMono}" FontSize="9"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource BrandBrush}"
                                           Margin="0,0,0,6" />
                                <TextBox x:Name="DaysBox"
                                         Width="100"
                                         Text="30"
                                         FontFamily="{StaticResource FontMono}" FontSize="13"
                                         Padding="10,8"
                                         Background="{DynamicResource BgRaisedBrush}"
                                         BorderBrush="{DynamicResource BorderSubtleBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         HorizontalContentAlignment="Right"
                                         IsEnabled="False" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Ignored for Lifetime/Partner/Dev plans."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Margin="2,4,0,16" />

                        <!-- Fingerprint -->
                        <TextBlock Text="CUSTOMER'S HARDWARE FINGERPRINT"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="FingerprintBox"
                                 FontFamily="{StaticResource FontMono}" FontSize="11"
                                 Padding="10,8"
                                 Background="{DynamicResource BgRaisedBrush}"
                                 BorderBrush="{DynamicResource BorderSubtleBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 MinHeight="56"
                                 VerticalScrollBarVisibility="Auto"
                                 CaretBrush="{DynamicResource BrandBrush}" />
                        <TextBlock x:Name="FingerprintHint"
                                   Text="Expected: 4 hex chunks of 32 chars each, joined by &quot;-&quot; (≈131 chars total)."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Margin="2,4,0,16" />

                        <!-- Output file -->
                        <TextBlock Text="OUTPUT FILENAME"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputBox" Grid.Column="0"
                                     Text="licenses\customer.lic"
                                     FontFamily="{StaticResource FontMono}" FontSize="12"
                                     Padding="10,8"
                                     Background="{DynamicResource BgRaisedBrush}"
                                     BorderBrush="{DynamicResource BorderSubtleBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource BrandBrush}" />
                            <Button Grid.Column="1"
                                    Content="Browse…"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,4" FontSize="11"
                                    Margin="6,0,0,0"
                                    Click="OnBrowseOutputClick" />
                        </Grid>
                        <TextBlock Text="Relative paths are resolved against the admin app's working directory."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Margin="2,4,0,0" />

                    </StackPanel>
                </Border>

                <!-- Action row -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ValidationText" Grid.Column="0"
                               Text="Fill in all fields to enable Mint."
                               FontSize="11"
                               Foreground="{DynamicResource TextDimBrush}"
                               VerticalAlignment="Center" />
                    <Button x:Name="MintButton" Grid.Column="1"
                            Content="Mint License"
                            Style="{StaticResource PrimaryButton}"
                            Padding="20,8" FontSize="13"
                            IsEnabled="False"
                            Click="OnMintClick" />
                </Grid>

                <!-- =====================================================
                     RESULT PANEL — shown after a successful mint
                     ===================================================== -->
                <Border x:Name="ResultPanel"
                        Visibility="Collapsed"
                        Background="#0E2A22"
                        BorderBrush="{DynamicResource StatusOkBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="22,18" Margin="0,22,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="✓" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource StatusOkBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="LICENSE MINTED"
                                       FontFamily="{StaticResource FontMono}" FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource StatusOkBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="LICENSE KEY"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ResultKeyText"
                                       FontFamily="{StaticResource FontMono}" FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,4" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="EMAIL"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ResultEmailText"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextStrongBrush}"
                                       Margin="0,0,0,4" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="PLAN / EXPIRES"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ResultPlanText"
                                       FontFamily="{StaticResource FontMono}" FontSize="12"
                                       Foreground="{DynamicResource TextStrongBrush}"
                                       Margin="0,0,0,4" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="FILE"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ResultPathText"
                                       FontFamily="{StaticResource FontMono}" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Reveal in Explorer"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6" FontSize="11"
                                    Margin="0,0,8,0"
                                    Click="OnRevealInExplorerClick" />
                            <Button Content="Copy summary to clipboard"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6" FontSize="11"
                                    Margin="0,0,8,0"
                                    Click="OnCopySummaryClick" />
                            <Button Content="Mint another"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6" FontSize="11"
                                    Click="OnMintAnotherClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- =====================================================
                     ERROR PANEL — shown if mint fails
                     ===================================================== -->
                <Border x:Name="ErrorPanel"
                        Visibility="Collapsed"
                        Background="#2A0E14"
                        BorderBrush="{DynamicResource StatusErrBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="22,18" Margin="0,22,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="✕" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource StatusErrBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="MINT FAILED"
                                       FontFamily="{StaticResource FontMono}" FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource StatusErrBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="ErrorText"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextStrongBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
