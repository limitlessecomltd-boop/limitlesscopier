<UserControl x:Class="LTC.AdminApp.Views.Tabs.MintTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Mint tab — server-based flow.

        Operator fills Email + Plan (+ Days if Daily) + optional Notes,
        clicks Mint. App calls POST /admin/keys/issue on the activation
        server with the bearer token. Server returns a license key string
        like LTC-LIFE-XXXX-YYYY-ZZZZ. We display it big with a one-click
        "Copy email body" button so the operator can paste straight into
        their reply.

        Compared to the old flow, we no longer need the customer's
        fingerprint (the activation server binds it at customer
        /activate time) and there is no output .lic file.
    -->
    <Grid Background="{DynamicResource BgBaseBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="32,24,32,24">
            <StackPanel MaxWidth="780" HorizontalAlignment="Left">
                <!-- Page header -->
                <TextBlock Text="MINT LICENSE"
                           FontFamily="{StaticResource FontDisplay}" FontSize="28"
                           Foreground="{DynamicResource TextStrongBrush}"
                           LineHeight="28" />
                <TextBlock Text="Issue a license key. The customer pastes the key into their app; the server binds it to their machine on first activation."
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,16" />

                <!-- Configuration banner shown when settings are missing -->
                <Border x:Name="NotConfiguredBanner"
                        Visibility="Collapsed"
                        Background="#2A1F0E"
                        BorderBrush="{DynamicResource StatusWarnBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="18,12" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource StatusWarnBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextStrongBrush}"
                                   TextWrapping="Wrap">
                            <Run Text="Server connection not configured."/>
                            <Run Text=" Open the Settings tab and enter your bearer token before minting."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- =====================================================
                     FORM PANEL
                     ===================================================== -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="22,18">
                    <StackPanel>
                        <!-- Email -->
                        <TextBlock Text="CUSTOMER EMAIL"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="EmailBox"
                                 FontFamily="{StaticResource FontUi}" FontSize="13"
                                 Padding="10,8"
                                 Background="{DynamicResource BgRaisedBrush}"
                                 BorderBrush="{DynamicResource BorderSubtleBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Stored with the license; shown in the customer's Settings → License."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Margin="2,4,0,16" />

                        <!-- Plan -->
                        <TextBlock Text="PLAN"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox x:Name="PlanBox"
                                  FontFamily="{StaticResource FontUi}" FontSize="13"
                                  Padding="10,6"
                                  Background="{DynamicResource BgRaisedBrush}"
                                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  SelectedIndex="0"
                                  SelectionChanged="OnPlanSelectionChanged">
                            <ComboBoxItem Content="Lifetime" />
                            <ComboBoxItem Content="Daily" />
                            <ComboBoxItem Content="Partner" />
                            <ComboBoxItem Content="Dev" />
                        </ComboBox>
                        <TextBlock Text="Lifetime = no expiry. Daily = enter days below. Partner/Dev are no-expiry internal tiers."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   TextWrapping="Wrap"
                                   Margin="2,4,0,16" />

                        <!-- Expiry days -->
                        <StackPanel>
                            <TextBlock Text="EXPIRES IN (DAYS)"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource BrandBrush}"
                                       Margin="0,0,0,6" />
                            <TextBox x:Name="DaysBox"
                                     Width="100"
                                     Text="30"
                                     FontFamily="{StaticResource FontMono}" FontSize="13"
                                     Padding="10,8"
                                     Background="{DynamicResource BgRaisedBrush}"
                                     BorderBrush="{DynamicResource BorderSubtleBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     HorizontalContentAlignment="Right"
                                     HorizontalAlignment="Left"
                                     IsEnabled="False" />
                            <TextBlock Text="Only used for Daily plans. Ignored otherwise."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Margin="2,4,0,16" />
                        </StackPanel>

                        <!-- Notes -->
                        <TextBlock Text="NOTES (OPTIONAL)"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="NotesBox"
                                 FontFamily="{StaticResource FontUi}" FontSize="12"
                                 Padding="10,8"
                                 Background="{DynamicResource BgRaisedBrush}"
                                 BorderBrush="{DynamicResource BorderSubtleBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="44"
                                 MaxHeight="100"
                                 VerticalScrollBarVisibility="Auto"
                                 CaretBrush="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Internal notes for this license (Stripe ref, partner deal, etc.). Stored server-side; not shown to the customer."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   TextWrapping="Wrap"
                                   Margin="2,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Action row -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="ValidationText"
                                   Text="Fill in email to enable Mint."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="BusyText"
                                   Text="  Contacting server…"
                                   Visibility="Collapsed"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                    </StackPanel>

                    <Button x:Name="MintButton" Grid.Column="1"
                            Content="Mint License"
                            Style="{StaticResource PrimaryButton}"
                            Padding="20,8" FontSize="13"
                            IsEnabled="False"
                            Click="OnMintClick" />
                </Grid>

                <!-- =====================================================
                     RESULT PANEL — shown after a successful mint
                     ===================================================== -->
                <Border x:Name="ResultPanel"
                        Visibility="Collapsed"
                        Background="#0E2A22"
                        BorderBrush="{DynamicResource StatusOkBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="22,18" Margin="0,22,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="✓" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource StatusOkBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="LICENSE ISSUED"
                                       FontFamily="{StaticResource FontMono}" FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource StatusOkBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- The key, big -->
                        <TextBlock Text="LICENSE KEY"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Margin="0,0,0,6" />
                        <Border Background="{DynamicResource BgRaisedBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="14,10" Margin="0,0,0,14">
                            <TextBox x:Name="ResultKeyText"
                                     IsReadOnly="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontFamily="{StaticResource FontMono}" FontSize="18"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                        </Border>

                        <!-- Details -->
                        <Grid Margin="0,0,0,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="EMAIL"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ResultEmailText"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextStrongBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="PLAN / EXPIRES"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ResultPlanText"
                                       FontFamily="{StaticResource FontMono}" FontSize="12"
                                       Foreground="{DynamicResource TextStrongBrush}"
                                       Margin="0,0,0,4" />
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Copy key"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="14,6" FontSize="11"
                                    Margin="0,0,8,0"
                                    Click="OnCopyKeyClick" />
                            <Button Content="Copy email body"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6" FontSize="11"
                                    Margin="0,0,8,0"
                                    Click="OnCopyEmailClick" />
                            <Button Content="Mint another"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,6" FontSize="11"
                                    Click="OnMintAnotherClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- =====================================================
                     ERROR PANEL — shown if mint fails
                     ===================================================== -->
                <Border x:Name="ErrorPanel"
                        Visibility="Collapsed"
                        Background="#2A0E14"
                        BorderBrush="{DynamicResource StatusErrBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="22,18" Margin="0,22,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="✕" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource StatusErrBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <TextBlock Text="MINT FAILED"
                                       FontFamily="{StaticResource FontMono}" FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource StatusErrBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="ErrorText"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextStrongBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
