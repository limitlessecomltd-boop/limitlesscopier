<UserControl x:Class="LTC.AdminApp.Views.Tabs.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Settings tab — configure the activation server connection.
        The operator enters the API URL (default: api.limitlesscopier.com)
        and bearer token. Persisted to
        %LOCALAPPDATA%\LimitlessTradeCopierAdmin\settings.json.
    -->
    <Grid Background="{DynamicResource BgBaseBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24,32,24">
            <StackPanel MaxWidth="780" HorizontalAlignment="Left">
                <TextBlock Text="SETTINGS"
                           FontFamily="{StaticResource FontDisplay}" FontSize="28"
                           Foreground="{DynamicResource TextStrongBrush}"
                           LineHeight="28" />
                <TextBlock Text="Connection to the activation server. Enter once; persisted per Windows user."
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,24" />

                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="22,18">
                    <StackPanel>
                        <!-- API URL -->
                        <TextBlock Text="ACTIVATION SERVER URL"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="ApiUrlBox"
                                 FontFamily="{StaticResource FontMono}" FontSize="13"
                                 Padding="10,8"
                                 Background="{DynamicResource BgRaisedBrush}"
                                 BorderBrush="{DynamicResource BorderSubtleBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Default: https://api.limitlesscopier.com (production). Use a localhost URL for dev testing."
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   TextWrapping="Wrap"
                                   Margin="2,4,0,16" />

                        <!-- Bearer token -->
                        <TextBlock Text="ADMIN BEARER TOKEN"
                                   FontFamily="{StaticResource FontMono}" FontSize="9"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource BrandBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="BearerTokenBox"
                                 FontFamily="{StaticResource FontMono}" FontSize="12"
                                 Padding="10,8"
                                 Background="{DynamicResource BgRaisedBrush}"
                                 BorderBrush="{DynamicResource BorderSubtleBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource BrandBrush}" />
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   Margin="2,4,0,16">
                            <Run Text="The value of the server's "/>
                            <Run Text="Admin:BearerToken" FontFamily="{StaticResource FontMono}"/>
                            <Run Text=" setting. Treat this as a real secret — anyone with it can mint and revoke licenses."/>
                        </TextBlock>

                        <!-- Buttons row -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Save"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="20,8" FontSize="13"
                                    Margin="0,0,8,0"
                                    Click="OnSaveClick" />
                            <Button Content="Test connection"
                                    Style="{StaticResource GhostButton}"
                                    Padding="16,8" FontSize="12"
                                    Click="OnTestClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status panel -->
                <Border x:Name="StatusPanel"
                        Visibility="Collapsed"
                        BorderThickness="1" CornerRadius="6"
                        Padding="18,14" Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="StatusIcon" Text="✓"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <TextBlock x:Name="StatusText"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextStrongBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
