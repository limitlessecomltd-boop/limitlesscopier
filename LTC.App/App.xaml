<Application x:Class="LTC.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LTC.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Palette.Dark.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <conv:ResourceKeyToBrushConverter x:Key="KeyToBrush" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
