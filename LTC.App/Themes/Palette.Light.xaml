<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =====================================================================
         SWISS-MINIMAL LIGHT PALETTE
         Cream paper background, charcoal text, single orange accent. The
         brush KEYS match Palette.Dark.xaml exactly so we can swap dictionaries
         at runtime without changing any control templates or views.
         ===================================================================== -->

    <!-- Backgrounds: cream "paper" hierarchy -->
    <Color x:Key="BgVoid">#F2F0EA</Color>      <!-- chrome (top bar, status bar) — slightly darker cream -->
    <Color x:Key="BgBase">#FAFAF8</Color>      <!-- main panes — soft white -->
    <Color x:Key="BgDeep">#F5F4EE</Color>      <!-- center pane (deeper) -->
    <Color x:Key="BgPanel">#FFFFFF</Color>     <!-- nodes / cards: pure white for contrast -->
    <Color x:Key="BgSelected">#F0EFE8</Color>  <!-- selected card -->
    <Color x:Key="BgHover">#F5F4EE</Color>     <!-- hover state -->
    <Color x:Key="BgRaised">#FFFFFF</Color>    <!-- elevated chip / tag bg -->

    <!-- Borders: soft hairlines on cream -->
    <Color x:Key="BorderFaint">#EDEBE5</Color>
    <Color x:Key="BorderSubtle">#E8E6E0</Color>
    <Color x:Key="BorderDefault">#D8D5CC</Color>
    <Color x:Key="BorderStrong">#BCB8AB</Color>
    <Color x:Key="BorderMaster">#9DC3D4</Color>     <!-- soft cyan tint -->
    <Color x:Key="BorderSlave">#E8B380</Color>      <!-- soft amber tint -->

    <!-- Text: charcoal hierarchy on cream -->
    <Color x:Key="TextPrimary">#1A1A1A</Color>      <!-- numbers, headers -->
    <Color x:Key="TextStrong">#2D2D2D</Color>       <!-- secondary names -->
    <Color x:Key="TextMuted">#6B6B6B</Color>        <!-- meta info -->
    <Color x:Key="TextDim">#888888</Color>          <!-- timestamps -->
    <Color x:Key="TextFaint">#B0AFA8</Color>        <!-- labels, IDs -->

    <!-- Accent: warm orange single signal color (Swiss minimal style) -->
    <Color x:Key="Brand">#FF6B00</Color>            <!-- primary action: deeper orange than dark theme -->
    <Color x:Key="BrandDim">#E55A00</Color>
    <Color x:Key="BrandGlow">#FF8530</Color>

    <Color x:Key="Accent">#0070BB</Color>           <!-- secondary: deeper blue (cyan washes out on white) -->
    <Color x:Key="AccentDim">#005A99</Color>

    <!-- Master/slave role tints -->
    <Color x:Key="Master">#0070BB</Color>           <!-- blue -->
    <Color x:Key="Slave">#FF6B00</Color>            <!-- orange -->

    <!-- Status: deeper saturations (light bg needs more punch on the dark side) -->
    <Color x:Key="StatusOk">#00875A</Color>         <!-- forest green -->
    <Color x:Key="StatusWarn">#D17B00</Color>       <!-- deep amber -->
    <Color x:Key="StatusErr">#C5363B</Color>        <!-- crimson -->

    <!-- Tints for pill backgrounds (very subtle on light bg) -->
    <Color x:Key="OkTint">#E8F4EE</Color>
    <Color x:Key="WarnTint">#FAE8D4</Color>
    <Color x:Key="ErrTint">#FAE0E0</Color>
    <Color x:Key="BrandTint">#FFEAD6</Color>
    <Color x:Key="AccentTint">#DDEBF6</Color>

    <!-- ====================================================================
         Brushes (same keys as dark palette so everything Just Works)
         ==================================================================== -->
    <SolidColorBrush x:Key="BgVoidBrush"     Color="{StaticResource BgVoid}" />
    <SolidColorBrush x:Key="BgBaseBrush"     Color="{StaticResource BgBase}" />
    <SolidColorBrush x:Key="BgDeepBrush"     Color="{StaticResource BgDeep}" />
    <SolidColorBrush x:Key="BgPanelBrush"    Color="{StaticResource BgPanel}" />
    <SolidColorBrush x:Key="BgSelectedBrush" Color="{StaticResource BgSelected}" />
    <SolidColorBrush x:Key="BgHoverBrush"    Color="{StaticResource BgHover}" />
    <SolidColorBrush x:Key="BgRaisedBrush"   Color="{StaticResource BgRaised}" />

    <SolidColorBrush x:Key="BorderFaintBrush"   Color="{StaticResource BorderFaint}" />
    <SolidColorBrush x:Key="BorderSubtleBrush"  Color="{StaticResource BorderSubtle}" />
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}" />
    <SolidColorBrush x:Key="BorderStrongBrush"  Color="{StaticResource BorderStrong}" />
    <SolidColorBrush x:Key="BorderMasterBrush"  Color="{StaticResource BorderMaster}" />
    <SolidColorBrush x:Key="BorderSlaveBrush"   Color="{StaticResource BorderSlave}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextStrongBrush"  Color="{StaticResource TextStrong}" />
    <SolidColorBrush x:Key="TextMutedBrush"   Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="TextDimBrush"     Color="{StaticResource TextDim}" />
    <SolidColorBrush x:Key="TextFaintBrush"   Color="{StaticResource TextFaint}" />

    <SolidColorBrush x:Key="BrandBrush"      Color="{StaticResource Brand}" />
    <SolidColorBrush x:Key="BrandDimBrush"   Color="{StaticResource BrandDim}" />
    <SolidColorBrush x:Key="BrandGlowBrush"  Color="{StaticResource BrandGlow}" />
    <SolidColorBrush x:Key="AccentBrush"     Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentDimBrush"  Color="{StaticResource AccentDim}" />

    <SolidColorBrush x:Key="MasterBrush"     Color="{StaticResource Master}" />
    <SolidColorBrush x:Key="SlaveBrush"      Color="{StaticResource Slave}" />

    <SolidColorBrush x:Key="StatusOkBrush"   Color="{StaticResource StatusOk}" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="{StaticResource StatusWarn}" />
    <SolidColorBrush x:Key="StatusErrBrush"  Color="{StaticResource StatusErr}" />

    <SolidColorBrush x:Key="OkTintBrush"     Color="{StaticResource OkTint}" />
    <SolidColorBrush x:Key="WarnTintBrush"   Color="{StaticResource WarnTint}" />
    <SolidColorBrush x:Key="ErrTintBrush"    Color="{StaticResource ErrTint}" />
    <SolidColorBrush x:Key="BrandTintBrush"  Color="{StaticResource BrandTint}" />
    <SolidColorBrush x:Key="AccentTintBrush" Color="{StaticResource AccentTint}" />

    <!-- Typography -->
    <!-- Typography (matches Palette.Dark — keeping keys in sync so swapping
         palettes doesn't change the fonts, only the colors). -->
    <FontFamily x:Key="FontUi">./Fonts/#DM Sans, Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="FontMono">./Fonts/#DM Mono, Cascadia Mono, Consolas</FontFamily>
    <FontFamily x:Key="FontDisplay">./Fonts/#Bebas Neue, Impact, Arial Black</FontFamily>

</ResourceDictionary>
