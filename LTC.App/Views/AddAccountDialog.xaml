<Window x:Class="LTC.App.Views.AddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add account"
        Icon="/Assets/ltc-icon.ico"
        Height="760" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontUi}"
        FontSize="11"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="DialogLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontUi}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <!-- Radio-as-card style. The visible border, padding, and color
             changes based on IsChecked; the radio bullet is hidden so it
             reads as a clickable selectable tile. -->
        <Style x:Key="AccountKindCard" TargetType="RadioButton">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Box"
                                Background="{DynamicResource BgPanelBrush}"
                                BorderBrush="{DynamicResource BorderFaintBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Top" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush"
                                        Value="{DynamicResource BorderSubtleBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush"
                                        Value="{DynamicResource BrandBrush}" />
                                <Setter TargetName="Box" Property="Background"
                                        Value="{DynamicResource BgRaisedBrush}" />
                                <Setter TargetName="Box" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Add MT5 account"
                       FontFamily="{StaticResource FontUi}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Credentials are stored encrypted on this machine via Windows DPAPI."
                       Style="{StaticResource TextBody}" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ============ Auto-detect banner (changes color/text dynamically) ============ -->
                <Border x:Name="DetectBanner"
                        Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BrandBrush}"
                        BorderThickness="0,0,0,2"
                        CornerRadius="4"
                        Padding="14,12"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="DetectIcon" Text="⏳" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" x:Name="DetectTitle"
                                       Text="Detecting broker IP from MetaTrader 5…"
                                       FontFamily="{StaticResource FontUi}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextStrongBrush}"
                                       VerticalAlignment="Center" />
                            <!-- Refresh: re-run the detection. Useful when MT5 was
                                 just opened, or when a different terminal was
                                 brought to focus, and the user wants to recheck. -->
                            <Button Grid.Column="2" x:Name="RefreshDetectButton"
                                    Content="↻ Refresh"
                                    Click="OnRefreshDetectClick"
                                    Padding="10,3" FontSize="10.5"
                                    Background="{DynamicResource BgRaisedBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    Foreground="{DynamicResource TextMutedBrush}"
                                    Cursor="Hand"
                                    ToolTip="Re-scan the running MetaTrader 5 terminal for its broker IP" />
                        </Grid>
                        <TextBlock x:Name="DetectBody"
                                   TextWrapping="Wrap" Margin="0,8,0,0"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="Please open MetaTrader 5, log into the account you want to add, and keep the window active. Close any other MT5 windows. We'll detect the broker IP automatically." />
                        <Button x:Name="ManualHelpButton"
                                Style="{StaticResource GhostButton}"
                                Content="Show manual instructions"
                                Visibility="Collapsed"
                                HorizontalAlignment="Left"
                                Click="OnManualHelpClick"
                                Margin="0,8,0,0" Padding="10,4" />
                    </StackPanel>
                </Border>

                <TextBlock Text="Display name" Style="{StaticResource DialogLabel}" />
                <TextBox x:Name="NameBox" Margin="0,0,0,16" />

                <!-- ========== ACCOUNT TYPE ========== -->
                <!-- Three cards. Personal = retail, no extra fields. Prop
                     Challenge / Prop Funded = unlocks the prop firm section
                     further down. The selection state lives in radio buttons
                     hidden inside each card so WPF handles "only one selected"
                     for free; the visual style is custom via ToggleButton
                     would have been heavier, this is simpler. -->
                <TextBlock Text="Account type" Style="{StaticResource DialogLabel}" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="KindPersonalRadio"
                                 Grid.Column="0"
                                 GroupName="AccountKind"
                                 Style="{StaticResource AccountKindCard}"
                                 IsChecked="True"
                                 Checked="OnAccountKindChanged"
                                 Tag="Personal">
                        <StackPanel>
                            <TextBlock Text="●" FontSize="16"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="PERSONAL"
                                       FontFamily="{StaticResource FontMono}" FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Your own money"
                                       FontSize="10" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextDimBrush}" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="KindChallengeRadio"
                                 Grid.Column="2"
                                 GroupName="AccountKind"
                                 Style="{StaticResource AccountKindCard}"
                                 Checked="OnAccountKindChanged"
                                 Tag="PropChallenge">
                        <StackPanel>
                            <TextBlock Text="◇" FontSize="16"
                                       Foreground="{DynamicResource BrandBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="CHALLENGE"
                                       FontFamily="{StaticResource FontMono}" FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Prop firm evaluation"
                                       FontSize="10" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextDimBrush}" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="KindFundedRadio"
                                 Grid.Column="4"
                                 GroupName="AccountKind"
                                 Style="{StaticResource AccountKindCard}"
                                 Checked="OnAccountKindChanged"
                                 Tag="PropFunded">
                        <StackPanel>
                            <TextBlock Text="◆" FontSize="16"
                                       Foreground="{DynamicResource BrandBrush}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="FUNDED"
                                       FontFamily="{StaticResource FontMono}" FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Live prop capital"
                                       FontSize="10" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextDimBrush}" />
                        </StackPanel>
                    </RadioButton>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Login (account number)" Style="{StaticResource DialogLabel}" />
                        <TextBox x:Name="LoginBox" Margin="0,0,0,12" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Role" Style="{StaticResource DialogLabel}" />
                        <ComboBox x:Name="RoleBox" Margin="0,0,0,12" SelectedIndex="0">
                            <ComboBoxItem Content="Master" />
                            <ComboBoxItem Content="Slave" />
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Password" Style="{StaticResource DialogLabel}" />
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Host (broker IP)" Style="{StaticResource DialogLabel}" />
                        <TextBox x:Name="HostBox" Margin="0,0,0,12" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Port" Style="{StaticResource DialogLabel}" />
                        <TextBox x:Name="PortBox" Text="443" Margin="0,0,0,12" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Broker label (optional)" Style="{StaticResource DialogLabel}" />
                <TextBox x:Name="BrokerBox" Margin="0,0,0,16" />

                <!-- Symbol affix section -->
                <TextBlock Text="Symbol naming"
                           FontFamily="{StaticResource FontUi}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextStrongBrush}"
                           Margin="0,0,0,4" />
                <TextBlock Text="If this broker uses a prefix or suffix on symbol names (e.g. XAUUSDecn or m.EURUSD), enter it below. After the account connects, click 'Suggest from symbols' to auto-detect from the broker's catalog."
                           Style="{StaticResource TextBody}" Margin="0,0,0,10" TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Symbol prefix" Style="{StaticResource DialogLabel}" />
                        <TextBox x:Name="PrefixBox" Margin="0,0,0,12" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Symbol suffix" Style="{StaticResource DialogLabel}" />
                        <TextBox x:Name="SuffixBox" Margin="0,0,0,12" />
                    </StackPanel>
                </Grid>

                <!-- ===================================================
                     PROP FIRM SECTION
                     Hidden when Personal is selected, revealed when
                     Challenge or Funded is picked. Trader enters every
                     value from their own firm's dashboard — we don't
                     ship presets or verify anything.
                     =================================================== -->
                <StackPanel x:Name="PropSection" Visibility="Collapsed" Margin="0,16,0,0">

                    <Border Background="{DynamicResource BgPanelBrush}"
                            BorderBrush="{DynamicResource BorderFaintBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="PROP FIRM DETAILS"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandBrush}"
                                       Margin="0,0,0,8" />
                            <!-- The "you own these numbers" disclaimer line, per
                                 the legal-positioning decision. Calm, factual,
                                 makes our position unambiguous. -->
                            <TextBlock TextWrapping="Wrap" FontSize="10"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Text="Enter every value exactly as your prop firm's dashboard shows it. We track these numbers and warn you as you approach them — we don't verify them against the firm's rules. Limits are enforced by your firm, not by us." />
                        </StackPanel>
                    </Border>

                    <!-- Firm name + phase -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Firm name (any)" Style="{StaticResource DialogLabel}" />
                            <TextBox x:Name="FirmNameBox" Margin="0,0,0,12" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Phase" Style="{StaticResource DialogLabel}" />
                            <ComboBox x:Name="PhaseBox" Margin="0,0,0,12" SelectedIndex="0"
                                      SelectionChanged="OnPhaseChanged">
                                <ComboBoxItem Content="Phase 1" />
                                <ComboBoxItem Content="Phase 2" />
                                <ComboBoxItem Content="Funded" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Starting balance -->
                    <TextBlock Text="Starting balance ($)" Style="{StaticResource DialogLabel}" />
                    <TextBox x:Name="StartingBalanceBox" Margin="0,0,0,12"
                             TextChanged="OnStartingBalanceChanged" />

                    <!-- Daily loss limit with helper buttons -->
                    <TextBlock Text="Daily loss limit ($)" Style="{StaticResource DialogLabel}" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DailyLimitBox" Grid.Column="0" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Style="{StaticResource GhostButton}"
                                    Content="4%" Click="OnDailyPercentClick" Tag="4"
                                    Padding="10,4" FontSize="10" Margin="0,0,4,0" />
                            <Button Style="{StaticResource GhostButton}"
                                    Content="5%" Click="OnDailyPercentClick" Tag="5"
                                    Padding="10,4" FontSize="10" Margin="0,0,4,0" />
                            <Button Style="{StaticResource GhostButton}"
                                    Content="6%" Click="OnDailyPercentClick" Tag="6"
                                    Padding="10,4" FontSize="10" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Tip: click a percentage to compute from your starting balance."
                               FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                               Margin="0,0,0,12" />

                    <!-- Max overall loss limit with helper buttons -->
                    <TextBlock Text="Maximum total loss ($)" Style="{StaticResource DialogLabel}" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MaxLimitBox" Grid.Column="0" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Style="{StaticResource GhostButton}"
                                    Content="5%" Click="OnMaxPercentClick" Tag="5"
                                    Padding="10,4" FontSize="10" Margin="0,0,4,0" />
                            <Button Style="{StaticResource GhostButton}"
                                    Content="10%" Click="OnMaxPercentClick" Tag="10"
                                    Padding="10,4" FontSize="10" Margin="0,0,4,0" />
                            <Button Style="{StaticResource GhostButton}"
                                    Content="12%" Click="OnMaxPercentClick" Tag="12"
                                    Padding="10,4" FontSize="10" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Same idea — these are generic percentages, not firm-specific."
                               FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                               Margin="0,0,0,12" />

                    <!-- Drawdown type -->
                    <TextBlock Text="Drawdown type" Style="{StaticResource DialogLabel}" />
                    <ComboBox x:Name="DrawdownTypeBox" Margin="0,0,0,4" SelectedIndex="0">
                        <ComboBoxItem Content="Static (limit fixed from starting balance)" />
                        <ComboBoxItem Content="Trailing (limit follows equity up, then freezes)" />
                        <ComboBoxItem Content="High-water-mark (limit always follows equity up)" />
                    </ComboBox>
                    <TextBlock TextWrapping="Wrap" FontSize="10"
                               Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,0,12"
                               Text="Check your firm's dashboard to find which one they use." />

                    <!-- Profit target (hidden on Funded) -->
                    <StackPanel x:Name="ProfitTargetSection">
                        <TextBlock Text="Profit target ($) — optional" Style="{StaticResource DialogLabel}" />
                        <TextBox x:Name="ProfitTargetBox" Margin="0,0,0,8" />
                        <CheckBox x:Name="CloseAllOnTargetHitBox"
                                  Content="Auto-close all positions on this account when target is hit"
                                  Foreground="{DynamicResource TextStrongBrush}"
                                  FontSize="11"
                                  Margin="0,0,0,4" />
                        <TextBlock TextWrapping="Wrap" FontSize="10"
                                   Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,0,12"
                                   Text="Locks in the win — once realized+floating P&amp;L reaches your target, all open positions on this account close automatically. One-shot per app session." />
                    </StackPanel>

                    <!-- Min trading days -->
                    <TextBlock Text="Minimum trading days — optional" Style="{StaticResource DialogLabel}" />
                    <TextBox x:Name="MinDaysBox" Margin="0,0,0,16" />

                    <!-- Max loss per trade (some firms cap single-trade drawdown) -->
                    <TextBlock Text="Max loss per trade (% of starting balance) — optional"
                               Style="{StaticResource DialogLabel}" />
                    <TextBox x:Name="MaxLossPerTradeBox" Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap" FontSize="10"
                               Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,0,16"
                               Text="Some firms cap how much you can lose on a single open position (e.g. 2% of starting balance). Leave blank if your firm doesn't have this rule. The Prop Journal tab will show a live meter when set." />

                    <!-- Safety automations (opt-in, default off) -->
                    <Border Background="{DynamicResource BgPanelBrush}"
                            BorderBrush="{DynamicResource BorderFaintBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12"
                            Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="SAFETY AUTOMATIONS  ·  OFF BY DEFAULT"
                                       FontFamily="{StaticResource FontMono}" FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandBrush}"
                                       Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="10"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       Margin="0,0,0,12"
                                       Text="Optionally let the copier act on your behalf as you approach the daily loss limit. Both are disabled until you enable them per account." />

                            <CheckBox x:Name="AutoPauseEnabled" Margin="0,0,0,4"
                                      Content="Stop copying new trades at "
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Grid Margin="20,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AutoPausePercentBox" Grid.Column="0" Text="80" />
                                <TextBlock Grid.Column="1" Text="  % of daily limit used"
                                           VerticalAlignment="Center" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </Grid>

                            <CheckBox x:Name="AutoCloseEnabled" Margin="0,0,0,4"
                                      Content="Force-close all positions at "
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Grid Margin="20,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AutoClosePercentBox" Grid.Column="0" Text="95" />
                                <TextBlock Grid.Column="1" Text="  % of daily limit used"
                                           VerticalAlignment="Center" FontSize="10"
                                           Foreground="{DynamicResource TextDimBrush}" />
                            </Grid>
                            <TextBlock TextWrapping="Wrap" FontSize="10"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       Margin="0,8,0,0"
                                       Text="Force-close runs after pause as a last resort. Manual override always works." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource StatusErrBrush}"
                       FontFamily="{StaticResource FontUi}" FontSize="11"
                       VerticalAlignment="Center" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource GhostButton}" Content="Cancel"
                        Margin="0,0,8,0" Click="OnCancelClick" IsCancel="True" />
                <Button Style="{StaticResource PrimaryButton}" Content="Add account"
                        Click="OnAddClick" IsDefault="True" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
