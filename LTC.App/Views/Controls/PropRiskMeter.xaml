<UserControl x:Class="LTC.App.Views.Controls.PropRiskMeter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LTC.App.Converters">
    <!--
        Risk meter widget. Bound to an AccountViewModel. Renders two
        horizontal bars (daily + overall) with color-coded fills and
        compact text labels showing both the percentage used and the
        dollar headroom remaining.

        Heights are tight so the control fits in an account row without
        making the row significantly taller — ~38px total. If a parent
        wants more breathing room they can wrap us in a Border with
        padding.

        Color logic lives in the view model (see DailyMeterColorKey).
        We use the KeyToBrush converter (already in App.xaml resources)
        to translate "StatusOkBrush" / "BrandBrush" / etc. into the
        actual brush from the current theme dictionary, so dark/light
        mode automatically apply.
    -->
    <UserControl.Resources>
        <conv:ResourceKeyToBrushConverter x:Key="KeyToBrushLocal" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- daily line + bar -->
            <RowDefinition Height="3" />      <!-- spacer -->
            <RowDefinition Height="Auto" />   <!-- overall line + bar -->
        </Grid.RowDefinitions>

        <!-- ============================================================
             DAILY ROW
             ============================================================ -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top line: "DAILY 62.4%   $1,420 left" -->
            <Grid Grid.Row="0" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="DAILY"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9" FontWeight="Medium"
                           Foreground="{DynamicResource TextDimBrush}"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{Binding DailyPercentText}"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{Binding DailyMeterColorKey, Converter={StaticResource KeyToBrushLocal}}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />

                <TextBlock Grid.Column="2"
                           Text="{Binding DailyHeadroomText}"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Bar itself: a track Border + a fill Rectangle whose width
                 is bound to DailyMeterValue as a percentage of the track. -->
            <Border Grid.Row="1"
                    Height="5"
                    CornerRadius="2.5"
                    Background="{DynamicResource BgRaisedBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0.5"
                    ClipToBounds="True">
                <Grid HorizontalAlignment="Stretch">
                    <Rectangle HorizontalAlignment="Left"
                               RadiusX="2" RadiusY="2"
                               Fill="{Binding DailyMeterColorKey, Converter={StaticResource KeyToBrushLocal}}">
                        <Rectangle.Width>
                            <MultiBinding>
                                <MultiBinding.Converter>
                                    <conv:PercentToWidthConverter />
                                </MultiBinding.Converter>
                                <Binding Path="DailyMeterValue" />
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}" />
                            </MultiBinding>
                        </Rectangle.Width>
                    </Rectangle>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================================
             OVERALL ROW
             ============================================================ -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="OVERALL"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9" FontWeight="Medium"
                           Foreground="{DynamicResource TextDimBrush}"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="{Binding OverallPercentText}"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9" FontWeight="SemiBold"
                           Foreground="{Binding OverallMeterColorKey, Converter={StaticResource KeyToBrushLocal}}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />

                <TextBlock Grid.Column="2"
                           Text="{Binding OverallHeadroomText}"
                           FontFamily="{DynamicResource FontMono}"
                           FontSize="9"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="1"
                    Height="5"
                    CornerRadius="2.5"
                    Background="{DynamicResource BgRaisedBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0.5"
                    ClipToBounds="True">
                <Grid HorizontalAlignment="Stretch">
                    <Rectangle HorizontalAlignment="Left"
                               RadiusX="2" RadiusY="2"
                               Fill="{Binding OverallMeterColorKey, Converter={StaticResource KeyToBrushLocal}}">
                        <Rectangle.Width>
                            <MultiBinding>
                                <MultiBinding.Converter>
                                    <conv:PercentToWidthConverter />
                                </MultiBinding.Converter>
                                <Binding Path="OverallMeterValue" />
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}" />
                            </MultiBinding>
                        </Rectangle.Width>
                    </Rectangle>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
