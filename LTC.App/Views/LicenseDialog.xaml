<Window x:Class="LTC.App.Views.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License — Limitless Trade Copier"
        Icon="/Assets/ltc-icon.ico"
        Height="560" Width="600"
        MinHeight="500" MinWidth="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        Background="{DynamicResource BgBaseBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontUi}"
        FontSize="12"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">
    <!--
        New license dialog for the hardware-bound activation system.
        Shows the customer their machine fingerprint (so they can email it
        to support) and accepts a .lic file to install. Falls back to the
        legacy key-paste flow for customers who already have an old-style
        license key from the simple licensing system.

        Layout:
          - Top: small brand mark + Title
          - Section 1: "Your machine fingerprint" box with copy button
          - Section 2: Two buttons — "Install license file" / "I have a license key"
          - Section 3: status banner (validation feedback)
          - Bottom: Quit button
    -->
    <!--
        DockPanel keeps the footer (Quit button) pinned to the bottom of the
        window at all times, even when the inner content scrolls. Everything
        above goes inside a ScrollViewer so users on small displays / low DPI
        can always reach the Install File button by scrolling.
    -->
    <DockPanel>
        <!-- Footer pinned to bottom — declared FIRST so DockPanel reserves space -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource BgBaseBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="28,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Quit"
                        Style="{StaticResource GhostButton}"
                        Padding="20,8" FontSize="12"
                        Click="OnQuitClick"
                        IsCancel="True" />
            </StackPanel>
        </Border>

        <!-- Scrollable content area -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0">
            <Grid Margin="28,28,28,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />     <!-- header -->
                    <RowDefinition Height="Auto" />     <!-- fingerprint -->
                    <RowDefinition Height="Auto" />     <!-- separator -->
                    <RowDefinition Height="Auto" />     <!-- install area -->
                    <RowDefinition Height="Auto" />     <!-- status banner -->
                </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
            <Grid Width="34" Height="18" Margin="0,0,10,0">
                <Ellipse Width="14" Height="14" Fill="{DynamicResource MasterBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Center" />
                <Ellipse Width="14" Height="14" Fill="{DynamicResource SlaveBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" />
                <Rectangle Width="5" Height="14" Fill="{DynamicResource BrandBrush}"
                           RadiusX="2.5" RadiusY="2.5"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
            <StackPanel>
                <TextBlock Text="LICENSE"
                           FontFamily="{StaticResource FontDisplay}" FontSize="22"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Activate Limitless Trade Copier on this machine"
                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Section 1: machine fingerprint -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16,14"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="THIS MACHINE'S FINGERPRINT"
                           FontFamily="{StaticResource FontMono}" FontSize="9"
                           FontWeight="Medium"
                           Foreground="{DynamicResource BrandBrush}"
                           Margin="0,0,0,8" />

                <!-- Short display version (8 chars) for a glance + full version in a box for copying -->
                <TextBlock x:Name="FingerprintShortText"
                           Text="••••••••"
                           FontFamily="{StaticResource FontMono}" FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,10" />

                <TextBlock TextWrapping="Wrap" FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,0,0,10"
                           Text="Send the full fingerprint below to support@limitlesscopier.com along with your payment receipt. You'll receive a license file (.lic) back — drop it in below." />

                <Border Background="{DynamicResource BgRaisedBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1" CornerRadius="3" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FingerprintFullText"
                                 Grid.Column="0"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 FontFamily="{StaticResource FontMono}" FontSize="10"
                                 Text="loading..."
                                 VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Copy"
                                Style="{StaticResource GhostButton}"
                                Padding="12,4" FontSize="10"
                                Click="OnCopyFingerprintClick" />
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Separator label -->
        <TextBlock Grid.Row="2" Text="ACTIVATE"
                   FontFamily="{StaticResource FontMono}" FontSize="9"
                   FontWeight="Medium"
                   Foreground="{DynamicResource TextDimBrush}"
                   Margin="0,4,0,8" />

        <!-- Section 2: install the .lic file. Single flow, no key paste,
             no online server — purely manual file install. -->
        <StackPanel Grid.Row="3">
            <Border Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="20,18" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Install your license file"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,6,0,14"
                               Text="After purchase, support emails you a .lic file generated from your machine fingerprint above. Click below to select it." />
                    <Button Content="Install license file…"
                            Style="{StaticResource PrimaryButton}"
                            Padding="22,10" FontSize="13"
                            HorizontalAlignment="Left"
                            Click="OnInstallLicFileClick" />
                </StackPanel>
            </Border>

            <TextBlock TextWrapping="Wrap"
                       FontSize="10"
                       Foreground="{DynamicResource TextDimBrush}"
                       Margin="4,4,0,0"
                       Text="Don't have a .lic file yet? Copy the fingerprint above and email it to support@limitlesscopier.com with your purchase receipt." />
        </StackPanel>

        <!-- Status banner -->
        <Border Grid.Row="4" x:Name="StatusBanner"
                Visibility="Collapsed"
                Background="{DynamicResource BgPanelBrush}"
                BorderThickness="0,0,0,2"
                Padding="14,10"
                Margin="0,12,0,0"
                CornerRadius="3">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusIcon" Text="✓"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock x:Name="StatusTitle"
                           FontSize="12" FontWeight="Medium"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
