<Window x:Class="LTC.App.Views.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:LTC.App.Views.Tabs"
        Title="Limitless Trade Copier"
        Icon="/Assets/ltc-icon.ico"
        Height="820" Width="1400" MinHeight="640" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBaseBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontUi}"
        FontSize="12"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <!--
        MainShell — the new windowed UI replacing the old single-page
        MainWindow. Three vertical regions:
          1. Top bar (48px)   — brand, health pill, live stats, theme/settings
          2. Body             — sidebar nav + active tab content
          3. Status bar (28px)— always-visible engine state ticker

        TextFormattingMode=Ideal + ClearType give the best font rendering
        WPF can produce. Still not as crisp as a browser but visibly
        better than the default "Display" mode.
    -->

    <Window.Resources>
        <!-- Sidebar nav item style. Same shape used for all five tabs. -->
        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="6,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Wrap" CornerRadius="6" Padding="10,9"
                                Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding Tag}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           VerticalAlignment="Center" />
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           x:Name="Badge"
                                           FontFamily="{StaticResource FontMono}"
                                           FontSize="10" FontWeight="Medium"
                                           Foreground="{DynamicResource TextFaintBrush}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Wrap" Property="Background"
                                        Value="{DynamicResource BorderSubtleBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Wrap" Property="Background"
                                        Value="{DynamicResource BgRaisedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />      <!-- top bar -->
            <RowDefinition Height="*" />       <!-- body -->
            <RowDefinition Height="28" />      <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ==============================================================
             TOP BAR
             ============================================================== -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgVoidBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="14,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- brand -->
                    <ColumnDefinition Width="Auto" />  <!-- version pill -->
                    <ColumnDefinition Width="Auto" />  <!-- health pill -->
                    <ColumnDefinition Width="*" />     <!-- spacer -->
                    <ColumnDefinition Width="Auto" />  <!-- live stats -->
                    <ColumnDefinition Width="Auto" />  <!-- actions -->
                </Grid.ColumnDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="34" Height="18" Margin="0,0,10,0">
                        <Ellipse Width="14" Height="14" Fill="{DynamicResource MasterBrush}"
                                 HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <Ellipse Width="14" Height="14" Fill="{DynamicResource SlaveBrush}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" />
                        <Rectangle Width="5" Height="14" Fill="{DynamicResource BrandBrush}"
                                   RadiusX="2.5" RadiusY="2.5"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel>
                        <TextBlock Text="LIMITLESS"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="20"
                                   Foreground="{DynamicResource TextPrimaryBrush}" LineHeight="20" />
                        <TextBlock Text="T R A D E   C O P I E R"
                                   FontFamily="{StaticResource FontMono}" FontSize="7"
                                   Foreground="{DynamicResource BrandBrush}" Margin="0,1,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Version pill -->
                <Border Grid.Column="1" Margin="14,0,0,0"
                        Background="{DynamicResource BgRaisedBrush}"
                        CornerRadius="3" Padding="6,3" VerticalAlignment="Center">
                    <TextBlock x:Name="VersionText" Text="v1.0.0"
                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                               Foreground="{DynamicResource TextDimBrush}" />
                </Border>

                <!-- Engine health pill -->
                <Border Grid.Column="2" Margin="10,0,0,0"
                        Background="{DynamicResource OkTintBrush}"
                        BorderBrush="{DynamicResource StatusOkBrush}"
                        BorderThickness="1"
                        CornerRadius="100" Padding="10,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource StatusOkBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock x:Name="HealthText" Text="Engine running"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                   Foreground="{DynamicResource StatusOkBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Live stats (right-aligned, compact)
                     Each stat: small dim label, 4px spacer, brand-colored
                     number. The MaxHeight on the outer panel prevents the
                     two text lines from overlapping when display fonts
                     have generous line metrics. -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,22,0">
                        <TextBlock Text="EQUITY"
                                   FontFamily="{StaticResource FontMono}" FontSize="8" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFaintBrush}"
                                   Margin="0,0,0,3" />
                        <TextBlock x:Name="TopEquityText"
                                   Text="{Binding TotalEquityText}"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="17"
                                   Foreground="{DynamicResource BrandBrush}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,22,0">
                        <TextBlock Text="FLOATING P&amp;L"
                                   FontFamily="{StaticResource FontMono}" FontSize="8" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFaintBrush}"
                                   Margin="0,0,0,3" />
                        <TextBlock x:Name="TopPLText"
                                   Text="{Binding FloatingPnlText}"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="17"
                                   Foreground="{Binding FloatingPnlColorKey, Converter={StaticResource KeyToBrush}}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,22,0">
                        <TextBlock Text="LATENCY"
                                   FontFamily="{StaticResource FontMono}" FontSize="8" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFaintBrush}"
                                   Margin="0,0,0,3" />
                        <TextBlock x:Name="TopLatencyText"
                                   Text="{Binding LatencyText}"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="17"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}"
                            Content="Close all" Padding="10,5"
                            Margin="0,0,6,0" Click="OnCloseAllEverywhereClick" />
                    <Button Style="{StaticResource GhostButton}"
                            Content="◐" Padding="8,5" ToolTip="Toggle theme"
                            Margin="0,0,6,0" Click="OnThemeToggleClick" />
                    <Button Style="{StaticResource GhostButton}"
                            Content="⚙" Padding="8,5" ToolTip="Settings"
                            Margin="0,0,6,0" Click="OnSettingsClick" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="+ Add account" Padding="14,5"
                            Click="OnAddAccountClick" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==============================================================
             BODY — sidebar nav + content area
             ============================================================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="WORKSPACE"
                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                               Foreground="{DynamicResource TextFaintBrush}"

                               Margin="18,0,0,8" />

                    <RadioButton x:Name="NavDashboard" Style="{StaticResource NavItem}"
                                 IsChecked="True" GroupName="Nav" Tag="●"
                                 Checked="OnNavChanged">
                        <TextBlock Text="Dashboard" Style="{StaticResource NavLabel}" />
                    </RadioButton>

                    <RadioButton x:Name="NavAccounts" Style="{StaticResource NavItem}"
                                 GroupName="Nav" Tag="▤"
                                 Checked="OnNavChanged">
                        <TextBlock Text="Accounts" Style="{StaticResource NavLabel}" />
                    </RadioButton>

                    <RadioButton x:Name="NavPropJournal" Style="{StaticResource NavItem}"
                                 GroupName="Nav" Tag="◆"
                                 Checked="OnNavChanged">
                        <TextBlock Text="Prop Journal" Style="{StaticResource NavLabel}" />
                    </RadioButton>

                    <RadioButton x:Name="NavLinks" Style="{StaticResource NavItem}"
                                 GroupName="Nav" Tag="⇄"
                                 Checked="OnNavChanged">
                        <TextBlock Text="Copy links" Style="{StaticResource NavLabel}" />
                    </RadioButton>

                    <RadioButton x:Name="NavPositions" Style="{StaticResource NavItem}"
                                 GroupName="Nav" Tag="▾"
                                 Checked="OnNavChanged">
                        <TextBlock Text="Positions" Style="{StaticResource NavLabel}" />
                    </RadioButton>

                    <RadioButton x:Name="NavActivity" Style="{StaticResource NavItem}"
                                 GroupName="Nav" Tag="≡"
                                 Checked="OnNavChanged">
                        <TextBlock Text="Activity" Style="{StaticResource NavLabel}" />
                    </RadioButton>

                    <Border Height="1" Background="{DynamicResource BorderSubtleBrush}"
                            Margin="18,16,18,16" />

                    <TextBlock Text="HELP"
                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                               Foreground="{DynamicResource TextFaintBrush}"

                               Margin="18,0,0,8" />
                    <RadioButton Style="{StaticResource NavItem}" GroupName="Nav" Tag="?"
                                 Click="OnHelpClick">
                        <TextBlock Text="Documentation" Style="{StaticResource NavLabel}" />
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Content area: holds the active tab.
                 Only one tab is visible at a time via Visibility binding
                 driven from the radio buttons' IsChecked. This avoids the
                 overhead of TabControl's content recycling and lets each
                 tab manage its own lifecycle. -->
            <Grid Grid.Column="1" Background="{DynamicResource BgBaseBrush}">
                <tabs:DashboardTab x:Name="TabDashboardContent"
                                   Visibility="{Binding IsChecked, ElementName=NavDashboard, Converter={StaticResource BoolToVis}}" />
                <tabs:AccountsTab x:Name="TabAccountsContent"
                                  Visibility="{Binding IsChecked, ElementName=NavAccounts, Converter={StaticResource BoolToVis}}" />
                <tabs:PropJournalTab x:Name="TabPropJournalContent"
                                    Visibility="{Binding IsChecked, ElementName=NavPropJournal, Converter={StaticResource BoolToVis}}" />
                <tabs:LinksTab x:Name="TabLinksContent"
                               Visibility="{Binding IsChecked, ElementName=NavLinks, Converter={StaticResource BoolToVis}}" />
                <tabs:PositionsTab x:Name="TabPositionsContent"
                                   Visibility="{Binding IsChecked, ElementName=NavPositions, Converter={StaticResource BoolToVis}}" />
                <tabs:ActivityTab x:Name="TabActivityContent"
                                  Visibility="{Binding IsChecked, ElementName=NavActivity, Converter={StaticResource BoolToVis}}" />

                <!-- First-run welcome overlay. Shown when there are zero
                     accounts. Hides the tabs entirely so a new user isn't
                     looking at empty pages. -->
                <Grid x:Name="WelcomeOverlay"
                      Background="{DynamicResource BgBaseBrush}"
                      Visibility="{Binding HasAnyAccount, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="520">
                        <TextBlock Text="WELCOME"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="72"
                                   Foreground="{DynamicResource BrandBrush}"
                                   HorizontalAlignment="Center"
                                   LineHeight="72" />
                        <TextBlock Text="L E T ' S   G E T   S T A R T E D"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"

                                   Foreground="{DynamicResource TextDimBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,32" />
                        <TextBlock Text="One app. Any number of MT5 accounts."
                                   FontSize="18" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420"
                                   FontSize="13" Foreground="{DynamicResource TextDimBrush}"
                                   Text="Limitless copies trades between your MT5 accounts in real time — no plugins, no provider EAs. To begin, add the first account you want to connect."
                                   Margin="0,0,0,32" />
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="+ Add your first account"
                                Padding="22,11" FontSize="13"
                                HorizontalAlignment="Center"
                                Click="OnAddAccountClick" />
                        <TextBlock HorizontalAlignment="Center" Margin="0,48,0,0"
                                   FontSize="11" Foreground="{DynamicResource TextFaintBrush}"
                                   Text="Need help? support@limitlesscopier.com" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- ==============================================================
             STATUS BAR
             ============================================================== -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{DynamicResource StatusOkBrush}"
                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="Engine running"
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TextDimBrush}" />
                    <TextBlock Text=" · "
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TextFaintBrush}" />
                    <TextBlock x:Name="StatusAccountsText" Text="0 accounts"
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TextDimBrush}" />
                    <TextBlock Text=" · "
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TextFaintBrush}" />
                    <TextBlock x:Name="StatusLinksText" Text="0 links"
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TextDimBrush}" />
                    <TextBlock Text=" · "
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TextFaintBrush}" />
                    <TextBlock x:Name="StatusPositionsText" Text="0 open"
                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                               Foreground="{DynamicResource TextDimBrush}" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource TextFaintBrush}"
                           VerticalAlignment="Center"
                           Text="v1.0.0" />
            </Grid>
        </Border>
    </Grid>
</Window>
