<Window x:Class="LTC.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Icon="/Assets/ltc-icon.ico"
        Height="540" Width="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgBaseBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontUi}"
        FontSize="11"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="SLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="SValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Margin" Value="0,4,0,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Settings"
                       FontFamily="{StaticResource FontUi}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="App information and storage locations."
                       Style="{StaticResource TextBody}" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="About" Style="{StaticResource SectionHeader}" />
                <TextBlock Text="App" Style="{StaticResource SLabel}" />
                <TextBlock x:Name="AppVersionText" Style="{StaticResource SValue}" />

                <TextBlock Text="License" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Email"
                               Style="{StaticResource SLabel}" Margin="0,0,16,4" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="LicEmailText"
                               Style="{StaticResource SValue}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Plan"
                               Style="{StaticResource SLabel}" Margin="0,0,16,4" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LicPlanText"
                               Style="{StaticResource SValue}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Issued"
                               Style="{StaticResource SLabel}" Margin="0,0,16,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LicIssuedText"
                               Style="{StaticResource SValue}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,16">
                    <Button Style="{StaticResource GhostButton}"
                            Content="Deactivate this device"
                            Click="OnDeactivateLicenseClick"
                            Padding="12,5" />
                </StackPanel>

                <TextBlock Text="Storage" Style="{StaticResource SectionHeader}" />
                <TextBlock Text="Database file" Style="{StaticResource SLabel}" />
                <TextBlock x:Name="DbPathText" Style="{StaticResource SValue}" />
                <TextBlock Text="Logs folder" Style="{StaticResource SLabel}" />
                <TextBlock x:Name="LogsPathText" Style="{StaticResource SValue}" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Style="{StaticResource GhostButton}" Content="Open logs folder"
                            Click="OnOpenLogsFolderClick" Padding="12,5" Margin="0,0,8,0" />
                    <Button Style="{StaticResource GhostButton}" Content="Open database folder"
                            Click="OnOpenDbFolderClick" Padding="12,5" />
                </StackPanel>

                <TextBlock Text="Appearance" Style="{StaticResource SectionHeader}" />
                <TextBlock Text="Theme" Style="{StaticResource SLabel}" />
                <ComboBox x:Name="ThemeBox"
                          Margin="0,0,0,16"
                          Width="240"
                          HorizontalAlignment="Left"
                          SelectionChanged="OnThemeChanged">
                    <ComboBoxItem Content="Dark — Trader Cockpit" Tag="Dark" />
                    <ComboBoxItem Content="Light — Swiss Minimal" Tag="Light" />
                </ComboBox>

                <TextBlock Text="Engine" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Accounts" Style="{StaticResource SLabel}" />
                        <TextBlock x:Name="AccountsCountText" Style="{StaticResource SValue}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Copy links" Style="{StaticResource SLabel}" />
                        <TextBlock x:Name="LinksCountText" Style="{StaticResource SValue}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Danger zone" Style="{StaticResource SectionHeader}"
                           Foreground="{DynamicResource StatusErrBrush}" />
                <TextBlock Text="Permanently delete all accounts, copy links, and saved settings. The app will close. Use this only if you want a fresh start."
                           Style="{StaticResource TextBody}" Margin="0,0,0,8" TextWrapping="Wrap" />
                <Button Style="{StaticResource GhostButton}"
                        Foreground="{DynamicResource StatusErrBrush}"
                        Content="Delete all data and reset"
                        Click="OnResetClick" Padding="12,5"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryButton}" Content="Close"
                    Click="OnCloseClick" IsCancel="True" IsDefault="True" Padding="14,5" />
        </Grid>
    </Grid>
</Window>
