<Window x:Class="LTC.App.Views.SymbolsExplorerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Broker symbols"
        Icon="/Assets/ltc-icon.ico"
        Height="640" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBaseBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontUi}"
        FontSize="11"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Broker symbols"
                       FontFamily="{StaticResource FontUi}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock x:Name="SubtitleText" Style="{StaticResource TextBody}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Suggestion banner -->
        <Border Grid.Row="1" x:Name="SuggestionBanner"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BrandBrush}"
                BorderThickness="0,0,0,2"
                CornerRadius="4"
                Padding="14,12"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Suggested naming pattern"
                               FontFamily="{StaticResource FontUi}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextStrongBrush}" />
                    <TextBlock x:Name="SuggestionText"
                               Style="{StaticResource TextBody}" Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                        Content="Apply"
                        Click="OnApplyClick" Padding="14,5"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Search -->
        <TextBox Grid.Row="2" x:Name="SearchBox"
                 Padding="8,5" Margin="0,0,0,8"
                 TextChanged="OnSearchChanged" />

        <!-- Symbol list -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SymbolList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderFaintBrush}"
                                    BorderThickness="0,0,0,1" Padding="12,6">
                                <TextBlock Text="{Binding}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" Style="{StaticResource TextBody}"
                       VerticalAlignment="Center" />
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource GhostButton}" Content="Close"
                    Click="OnCloseClick" IsCancel="True" IsDefault="True"
                    Padding="14,5" />
        </Grid>
    </Grid>
</Window>
