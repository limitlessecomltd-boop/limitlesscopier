<UserControl x:Class="LTC.App.Views.Tabs.AccountsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:LTC.App.Views.Controls"
             Background="{DynamicResource BgBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}"
             FontFamily="{StaticResource FontUi}"
             FontSize="12">
    <!--
        AccountsTab — dense table of all accounts (masters + slaves)
        in a single sortable view. Two ItemsControl instances stacked
        with the masters group above the slaves group. Each row is
        ~32px tall instead of the existing 90px cards, so 25 accounts
        fit on screen.
    -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Resources must be defined BEFORE any element that uses them in
             this Grid, because WPF resolves StaticResource at parse-time
             walking up the visual tree from the consumer. -->
        <Grid.Resources>
            <Style x:Key="TblHdr" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Grid.Resources>

        <!-- Title -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="ACCOUNTS"
                           FontFamily="{StaticResource FontDisplay}" FontSize="28"
                           Foreground="{DynamicResource TextStrongBrush}" LineHeight="28" />
                <TextBlock Text="Every connected MT5 account"
                           FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource TextFaintBrush}" Margin="0,3,0,0" />
            </StackPanel>
            <Button Style="{StaticResource PrimaryButton}"
                    Content="+ Add account" Padding="14,7"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="OnAddAccountClick" />
        </Grid>

        <!-- Column headers -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1,1,1,0"
                CornerRadius="8,8,0,0"
                Padding="14,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="ROLE" Style="{StaticResource TblHdr}" Grid.Column="0" />
                <TextBlock Text="ACCOUNT" Style="{StaticResource TblHdr}" Grid.Column="1" />
                <TextBlock Text="BROKER" Style="{StaticResource TblHdr}" Grid.Column="2" />
                <TextBlock Text="BALANCE" Style="{StaticResource TblHdr}" Grid.Column="3" HorizontalAlignment="Right" />
                <TextBlock Text="EQUITY" Style="{StaticResource TblHdr}" Grid.Column="4" HorizontalAlignment="Right" />
                <TextBlock Text="P&amp;L" Style="{StaticResource TblHdr}" Grid.Column="5" HorizontalAlignment="Right" />
                <TextBlock Text="CONNECTION" Style="{StaticResource TblHdr}" Grid.Column="6" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Body: masters then slaves -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,8,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Masters group header -->
                    <Border Background="{DynamicResource BgRaisedBrush}" Padding="14,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="MASTERS"
                                       FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource MasterBrush}" />
                            <TextBlock Text="{Binding Masters.Count}"
                                       FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Masters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1" Padding="14,9"
                                        Background="Transparent"
                                        MouseLeftButtonDown="OnAccountRowDoubleClick"
                                        Cursor="Hand">
                                    <Border.ContextMenu>
                                        <ContextMenu Background="{DynamicResource BgPanelBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                     FontFamily="{StaticResource FontUi}" FontSize="12">
                                            <MenuItem Header="Edit account…"
                                                      Tag="{Binding}"
                                                      Click="OnEditAccountClick" />
                                            <MenuItem Header="Close all positions on this account"
                                                      Tag="{Binding}"
                                                      Click="OnCloseAllOnAccountClick" />
                                            <Separator />
                                            <MenuItem Header="Delete account"
                                                      Tag="{Binding}"
                                                      Click="OnDeleteAccountClick" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel Background="Transparent">
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="2.5*" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Padding="6,2" CornerRadius="3"
                                                Background="{DynamicResource BorderMasterBrush}"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="MASTER"
                                                       FontFamily="{StaticResource FontMono}" FontSize="8" FontWeight="Medium"
                                                       Foreground="{DynamicResource MasterBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Login, StringFormat=#{0}}"
                                                       FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextDimBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding BrokerLabel}"
                                                   FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding BalanceText}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{Binding EquityText}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="5" Text="{Binding DailyPnlText}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                                   Foreground="{Binding DailyPnlColorKey, Converter={StaticResource KeyToBrush}}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="6" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8"
                                                     Fill="{Binding StatusColorKey, Converter={StaticResource KeyToBrush}}" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       Margin="6,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <!-- Prop firm risk meter (visible only for prop accounts). -->
                                    <ctrl:PropRiskMeter Margin="78,8,0,2"
                                                        Visibility="{Binding HasPropRisk, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Slaves group header -->
                    <Border Background="{DynamicResource BgRaisedBrush}" Padding="14,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SLAVES"
                                       FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource SlaveBrush}" />
                            <TextBlock Text="{Binding Slaves.Count}"
                                       FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       Margin="6,0,0,0" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Slaves}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1" Padding="14,9"
                                        Background="Transparent"
                                        MouseLeftButtonDown="OnAccountRowDoubleClick"
                                        Cursor="Hand">
                                    <Border.ContextMenu>
                                        <ContextMenu Background="{DynamicResource BgPanelBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                     FontFamily="{StaticResource FontUi}" FontSize="12">
                                            <MenuItem Header="Edit account…"
                                                      Tag="{Binding}"
                                                      Click="OnEditAccountClick" />
                                            <MenuItem Header="Close all positions on this account"
                                                      Tag="{Binding}"
                                                      Click="OnCloseAllOnAccountClick" />
                                            <Separator />
                                            <MenuItem Header="Delete account"
                                                      Tag="{Binding}"
                                                      Click="OnDeleteAccountClick" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel Background="Transparent">
                                    <Grid Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="2.5*" />
                                            <ColumnDefinition Width="1.5*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Padding="6,2" CornerRadius="3"
                                                Background="{DynamicResource BorderSlaveBrush}"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="SLAVE"
                                                       FontFamily="{StaticResource FontMono}" FontSize="8" FontWeight="Medium"
                                                       Foreground="{DynamicResource SlaveBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Login, StringFormat=#{0}}"
                                                       FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextDimBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding BrokerLabel}"
                                                   FontSize="11" Foreground="{DynamicResource TextDimBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding BalanceText}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{Binding EquityText}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="5" Text="{Binding DailyPnlText}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                                   Foreground="{Binding DailyPnlColorKey, Converter={StaticResource KeyToBrush}}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="6" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8"
                                                     Fill="{Binding StatusColorKey, Converter={StaticResource KeyToBrush}}" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       Margin="6,0,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <!-- Prop firm risk meter (visible only for prop accounts). -->
                                    <ctrl:PropRiskMeter Margin="78,8,0,2"
                                                        Visibility="{Binding HasPropRisk, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
