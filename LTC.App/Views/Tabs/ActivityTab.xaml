<UserControl x:Class="LTC.App.Views.Tabs.ActivityTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}"
             FontFamily="{StaticResource FontUi}"
             FontSize="12">
    <!--
        ActivityTab — the full event log. Bigger than the dashboard's
        activity sliver. Each row shows kind, symbol, detail, timestamp,
        latency.
    -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="ACTIVITY"
                           FontFamily="{StaticResource FontDisplay}" FontSize="28"
                           Foreground="{DynamicResource TextStrongBrush}" LineHeight="28" />
                <TextBlock Text="Every copy event, opens, closes, errors"
                           FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource TextFaintBrush}" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource GhostButton}"
                        Content="View raw logs" Padding="12,6" FontSize="11"
                        Margin="0,0,6,0" Click="OnLogsClick" />
                <Button Style="{StaticResource GhostButton}"
                        Content="Clear" Padding="12,6" FontSize="11"
                        Click="OnClearLogsClick" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource BgPanelBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Activity}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0,0,0,1" Padding="14,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding TimestampText}"
                                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                               Foreground="{DynamicResource TextFaintBrush}"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1" Padding="6,2" CornerRadius="3"
                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KindLabel}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                   Foreground="{Binding KindColorKey, Converter={StaticResource KeyToBrush}}" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Symbol}"
                                               FontFamily="{StaticResource FontMono}" FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding DetailLine}"
                                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                               Foreground="{DynamicResource TextDimBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding LatencyText}"
                                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                               Foreground="{DynamicResource StatusOkBrush}"
                                               VerticalAlignment="Center" Margin="10,0,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
