<UserControl x:Class="LTC.App.Views.Tabs.DashboardTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}"
             FontFamily="{StaticResource FontUi}"
             FontSize="12">
    <!--
        DashboardTab — the "at-a-glance" view. Density choices:
          - 4 KPI cards across the top (compact, fixed height)
          - Two-column body: accounts list left, positions+activity stack right
          - No giant empty-state hero — empty states sit inline in each panel
    -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />     <!-- page title -->
                <RowDefinition Height="Auto" />     <!-- KPI grid -->
                <RowDefinition Height="*" />        <!-- body -->
            </Grid.RowDefinitions>

            <!-- Page title (small, not screaming) -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="DASHBOARD"
                           FontFamily="{StaticResource FontDisplay}" FontSize="28"
                           Foreground="{DynamicResource TextStrongBrush}" LineHeight="28" />
                <TextBlock Text="Live overview — updated continuously"
                           FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                           Foreground="{DynamicResource TextFaintBrush}" Margin="0,3,0,0" />
            </StackPanel>

            <!-- KPI row -->
            <UniformGrid Grid.Row="1" Columns="4" Rows="1" Margin="0,0,0,16">
                <UniformGrid.Resources>
                    <Style x:Key="KpiCard" TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BgRaisedBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="Padding" Value="14,12" />
                        <Setter Property="Margin" Value="0,0,12,0" />
                    </Style>
                </UniformGrid.Resources>

                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="TOTAL EQUITY"
                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding TotalEquityText}"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="26"
                                   Foreground="{DynamicResource BrandBrush}" LineHeight="26" />
                        <TextBlock Text="{Binding TotalEquityChangeText}"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                   Foreground="{DynamicResource TextDimBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="FLOATING P&amp;L"
                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding FloatingPnlText}"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="26"
                                   Foreground="{Binding FloatingPnlColorKey, Converter={StaticResource KeyToBrush}}" LineHeight="26" />
                        <TextBlock Text="Open positions only"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                   Foreground="{DynamicResource TextDimBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="COPY LATENCY"
                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding LatencyText}"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="26"
                                   Foreground="{DynamicResource TextPrimaryBrush}" LineHeight="26" />
                        <TextBlock Text="Rolling average"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                   Foreground="{DynamicResource TextDimBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KpiCard}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="SUCCESS RATE"
                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,0,6" />
                        <TextBlock Text="{Binding SuccessRateText}"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="26"
                                   Foreground="{DynamicResource StatusOkBrush}" LineHeight="26" />
                        <TextBlock Text="{Binding TodayTradesText, StringFormat={}{0} trades today}"
                                   FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                   Foreground="{DynamicResource TextDimBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Body grid: accounts roll-up + activity feed -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: accounts list (light port from the old single-page UI) -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="14,10"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="▌ ACCOUNTS"
                                           FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                           Foreground="{DynamicResource TextDimBrush}" />
                                <TextBlock HorizontalAlignment="Right"
                                           FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                           Foreground="{DynamicResource TextFaintBrush}"
                                           Text="See full table in Accounts tab →" />
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="6,8">
                                <!-- Masters -->
                                <TextBlock Text="MASTERS"
                                           FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                           Foreground="{DynamicResource TextFaintBrush}"
                                           Margin="10,0,0,4" />
                                <ItemsControl ItemsSource="{Binding Masters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BgRaisedBrush}"
                                                    BorderBrush="{DynamicResource BorderFaintBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="14,10" Margin="4,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold" FontSize="12"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Login, StringFormat=#{0}}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextDimBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="10,0">
                                                        <TextBlock Text="{Binding EquityText}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding DailyPnlText}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                                   Foreground="{Binding DailyPnlColorKey, Converter={StaticResource KeyToBrush}}"
                                                                   HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                    <Ellipse Grid.Column="2" Width="8" Height="8"
                                                             Fill="{Binding StatusColorKey, Converter={StaticResource KeyToBrush}}"
                                                             VerticalAlignment="Center" Margin="6,0,0,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Slaves -->
                                <TextBlock Text="SLAVES"
                                           FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                           Foreground="{DynamicResource TextFaintBrush}"
                                           Margin="10,10,0,4" />
                                <ItemsControl ItemsSource="{Binding Slaves}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BgRaisedBrush}"
                                                    BorderBrush="{DynamicResource BorderFaintBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="14,10" Margin="4,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold" FontSize="12"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Login, StringFormat=#{0}}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextDimBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="10,0">
                                                        <TextBlock Text="{Binding EquityText}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding DailyPnlText}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                                   Foreground="{Binding DailyPnlColorKey, Converter={StaticResource KeyToBrush}}"
                                                                   HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                    <Ellipse Grid.Column="2" Width="8" Height="8"
                                                             Fill="{Binding StatusColorKey, Converter={StaticResource KeyToBrush}}"
                                                             VerticalAlignment="Center" Margin="6,0,0,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- RIGHT: positions on top, activity below -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource BgPanelBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="14,10"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="▌ OPEN POSITIONS"
                                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                               Foreground="{DynamicResource TextDimBrush}" />
                                    <TextBlock HorizontalAlignment="Right"
                                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                               Foreground="{DynamicResource TextFaintBrush}"
                                               Text="{Binding Positions.Count, StringFormat={}{0} active}" />
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Positions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="0,0,0,1" Padding="14,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Symbol}"
                                                                       FontWeight="Medium" FontSize="11"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding SideText}"
                                                                       FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                                       Foreground="{Binding SideColorKey, Converter={StaticResource KeyToBrush}}"
                                                                       Margin="6,0,0,0" />
                                                            <TextBlock Text="{Binding Volume, StringFormat={}{0:0.##}}"
                                                                       FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                                       Foreground="{DynamicResource TextDimBrush}"
                                                                       Margin="6,0,0,0" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ProfitText}"
                                                               FontFamily="{StaticResource FontMono}" FontSize="11"
                                                               Foreground="{Binding ProfitColorKey, Converter={StaticResource KeyToBrush}}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{DynamicResource BgPanelBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Padding="14,10"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="▌ ACTIVITY"
                                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                               Foreground="{DynamicResource TextDimBrush}" />
                                    <TextBlock HorizontalAlignment="Right"
                                               FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                               Foreground="{DynamicResource StatusOkBrush}"
                                               Text="● live" />
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Activity}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="0,0,0,1" Padding="14,7">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding KindLabel}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                                   Foreground="{Binding KindColorKey, Converter={StaticResource KeyToBrush}}"
                                                                   Margin="0,0,6,0" />
                                                        <TextBlock Text="{Binding Symbol}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="10"
                                                                   FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding TimestampText}"
                                                                   FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                                   Foreground="{DynamicResource TextDimBrush}"
                                                                   HorizontalAlignment="Right" Margin="6,0,0,0" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DetailLine}"
                                                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                               Foreground="{DynamicResource TextDimBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
