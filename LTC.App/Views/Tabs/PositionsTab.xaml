<UserControl x:Class="LTC.App.Views.Tabs.PositionsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}"
             FontFamily="{StaticResource FontUi}"
             FontSize="12">
    <!--
        PositionsTab — every open trade across every account in one dense
        table. Two columns: Master positions / Slave positions side by
        side, so the trader can see at a glance whether the slave
        actually got the master's trade.
    -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="POSITIONS"
                       FontFamily="{StaticResource FontDisplay}" FontSize="28"
                       Foreground="{DynamicResource TextStrongBrush}" LineHeight="28" />
            <TextBlock Text="All open trades, master vs slave"
                       FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                       Foreground="{DynamicResource TextFaintBrush}" Margin="0,3,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Master positions -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="14,10"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▌ ON MASTERS"
                                       FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                       Foreground="{DynamicResource MasterBrush}" />
                            <TextBlock Text="{Binding MasterPositions.Count, StringFormat={}{0} open}"
                                       FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       Margin="10,0,0,0" />
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MasterPositions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="0,0,0,1" Padding="14,9">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Symbol}"
                                                               FontWeight="Medium" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding SideText}"
                                                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                               Foreground="{Binding SideColorKey, Converter={StaticResource KeyToBrush}}"
                                                               Margin="8,0,0,0" />
                                                    <TextBlock Text="{Binding Volume, StringFormat={}{0:0.##} lot}"
                                                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                               Foreground="{DynamicResource TextDimBrush}"
                                                               Margin="8,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Ticket, StringFormat=#{0}}"
                                                           FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextFaintBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding ProfitText}"
                                                       FontFamily="{StaticResource FontMono}" FontSize="11"
                                                       Foreground="{Binding ProfitColorKey, Converter={StaticResource KeyToBrush}}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                            <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                                    Content="Close" Padding="8,3" FontSize="9"
                                                    Click="OnClosePositionClick" Tag="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Slave positions -->
            <Border Grid.Column="2"
                    Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="14,10"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▌ ON SLAVES"
                                       FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                       Foreground="{DynamicResource SlaveBrush}" />
                            <TextBlock Text="{Binding SlavePositions.Count, StringFormat={}{0} open}"
                                       FontFamily="{StaticResource FontMono}" FontSize="10" FontWeight="Medium"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       Margin="10,0,0,0" />
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SlavePositions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="0,0,0,1" Padding="14,9">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Symbol}"
                                                               FontWeight="Medium" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding SideText}"
                                                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                               Foreground="{Binding SideColorKey, Converter={StaticResource KeyToBrush}}"
                                                               Margin="8,0,0,0" />
                                                    <TextBlock Text="{Binding Volume, StringFormat={}{0:0.##} lot}"
                                                               FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                               Foreground="{DynamicResource TextDimBrush}"
                                                               Margin="8,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Ticket, StringFormat=#{0}}"
                                                           FontFamily="{StaticResource FontMono}" FontSize="9" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextFaintBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding ProfitText}"
                                                       FontFamily="{StaticResource FontMono}" FontSize="11"
                                                       Foreground="{Binding ProfitColorKey, Converter={StaticResource KeyToBrush}}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                            <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                                    Content="Close" Padding="8,3" FontSize="9"
                                                    Click="OnClosePositionClick" Tag="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
