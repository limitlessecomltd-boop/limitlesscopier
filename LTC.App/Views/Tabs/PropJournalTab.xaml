<UserControl x:Class="LTC.App.Views.Tabs.PropJournalTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LTC.App.Converters"
             Background="{DynamicResource BgBaseBrush}"
             Foreground="{DynamicResource TextPrimaryBrush}"
             FontFamily="{StaticResource FontUi}"
             FontSize="13">
    <!--
        Prop Journal tab — the live risk dashboard for prop firm accounts.

        Layout (top to bottom):
          1. Header row: page title + account switcher (when multiple accounts)
          2. Status banner: headline + body, color-coded by severity
          3. Four meter cards (1×4 grid): daily / overall / profit / trading days
          4. Six detail cards (3×2 grid): rules / live state / hurting /
             today / challenge stats / consistency
          5. Footer tip strip

        DataContext: PropJournalViewModel
    -->
    <UserControl.Resources>
        <conv:ResourceKeyToBrushConverter x:Key="LocalKeyToBrush" />
        <conv:PercentToWidthConverter x:Key="LocalPctToWidth" />

        <!-- Severity → background brush -->
        <Style x:Key="BannerStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20,18" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusSeverity}" Value="ok">
                    <Setter Property="Background" Value="{DynamicResource BgPanelBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource StatusOkBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusSeverity}" Value="caution">
                    <Setter Property="Background" Value="{DynamicResource BgPanelBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource StatusWarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusSeverity}" Value="danger">
                    <Setter Property="Background" Value="{DynamicResource BgPanelBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource StatusErrBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BannerIconStyle" TargetType="Border">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="52" />
            <Setter Property="CornerRadius" Value="26" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusSeverity}" Value="ok">
                    <Setter Property="Background" Value="{DynamicResource StatusOkBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusSeverity}" Value="caution">
                    <Setter Property="Background" Value="{DynamicResource StatusWarnBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusSeverity}" Value="danger">
                    <Setter Property="Background" Value="{DynamicResource StatusErrBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MeterCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18,16" />
        </Style>

        <Style x:Key="DetailCardStyle" TargetType="Border" BasedOn="{StaticResource MeterCardStyle}" />

        <Style x:Key="CardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0">

        <!-- ScrollViewer can only host ONE child. We wrap the empty-state
             grid and the main-content StackPanel in a single Grid so they
             overlap in the same cell — Visibility triggers (driven by
             HasAnyPropAccount) ensure only one is visible at a time. -->
        <Grid>

        <!-- Empty state when no prop accounts exist -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAnyPropAccount}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="40" MaxWidth="500">
                <TextBlock Text="No prop firm accounts yet."
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                           Text="This tab shows live risk meters for prop firm challenges and funded accounts. Add a Prop Challenge or Prop Funded account from the Accounts tab to start tracking your daily loss, overall drawdown, profit target, and trading days requirement." />
            </StackPanel>
        </Grid>

        <!-- Main content (visible when at least one prop account exists) -->
        <StackPanel Margin="24">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAnyPropAccount}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <!-- HEADER -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Prop Journal"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="700"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="12.5"
                               Text="Live view of how close you are to your firm's drawdown rules, your profit target, and the minimum trading days requirement. Stay above zero and you keep the account." />
                </StackPanel>

                <!-- Account switcher: ItemsControl of toggle-like buttons -->
                <Border Grid.Column="1" VerticalAlignment="Top"
                        Background="{DynamicResource BgRaisedBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="4">
                    <ItemsControl ItemsSource="{Binding PropAccounts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="OnAccountTabClick"
                                        Tag="{Binding}"
                                        Margin="2,0" Padding="12,6"
                                        FontSize="12"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource TextMutedBrush}"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Margin="0,0,8,0"
                                                             VerticalAlignment="Center"
                                                             Fill="{Binding DailyMeterColorKey, Converter={StaticResource KeyToBrush}}" />
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{TemplateBinding Foreground}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgPanelBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>

            <!-- STATUS BANNER -->
            <Border Style="{StaticResource BannerStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource BannerIconStyle}"
                            VerticalAlignment="Top" Margin="0,2,18,0">
                        <TextBlock Text="!" FontSize="26" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding StatusHeadline}"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding StatusBody}"
                                   FontSize="12.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                   MaxWidth="760" HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- FOUR METER GRID -->
            <Grid Margin="0,0,0,16" DataContext="{Binding SelectedAccount}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.Resources>
                    <Thickness x:Key="MeterCardMargin">0,0,12,0</Thickness>
                </Grid.Resources>

                <!-- DAILY LOSS LIMIT -->
                <Border Grid.Column="0" Style="{StaticResource MeterCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardLabelStyle}" Text="DAILY LOSS LIMIT" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding DailyPercentText}"
                                       FontFamily="{StaticResource FontMono}" FontSize="30" FontWeight="SemiBold"
                                       Foreground="{Binding DailyMeterColorKey, Converter={StaticResource KeyToBrush}}" />
                            <TextBlock Text="used" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       VerticalAlignment="Bottom" Margin="6,0,0,8" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,12"
                                   Text="{Binding DailyHeadroomText, StringFormat='You can lose {0} more today before breach.'}" />
                        <Border Height="7" CornerRadius="4"
                                Background="{DynamicResource BgRaisedBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0.5" ClipToBounds="True"
                                x:Name="DailyBarHost">
                            <Grid HorizontalAlignment="Stretch">
                                <Rectangle HorizontalAlignment="Left" RadiusX="3" RadiusY="3"
                                           Fill="{Binding DailyMeterColorKey, Converter={StaticResource KeyToBrush}}">
                                    <Rectangle.Width>
                                        <MultiBinding Converter="{StaticResource LocalPctToWidth}">
                                            <Binding Path="DailyMeterValue" />
                                            <Binding Path="ActualWidth" ElementName="DailyBarHost" />
                                        </MultiBinding>
                                    </Rectangle.Width>
                                </Rectangle>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- OVERALL DRAWDOWN -->
                <Border Grid.Column="1" Style="{StaticResource MeterCardStyle}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardLabelStyle}" Text="OVERALL DRAWDOWN" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding OverallPercentText}"
                                       FontFamily="{StaticResource FontMono}" FontSize="30" FontWeight="SemiBold"
                                       Foreground="{Binding OverallMeterColorKey, Converter={StaticResource KeyToBrush}}" />
                            <TextBlock Text="used" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       VerticalAlignment="Bottom" Margin="6,0,0,8" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,12"
                                   Text="{Binding OverallHeadroomText, StringFormat='You are {0} from the drawdown floor.'}" />
                        <Border Height="7" CornerRadius="4"
                                Background="{DynamicResource BgRaisedBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0.5" ClipToBounds="True"
                                x:Name="OverallBarHost">
                            <Grid HorizontalAlignment="Stretch">
                                <Rectangle HorizontalAlignment="Left" RadiusX="3" RadiusY="3"
                                           Fill="{Binding OverallMeterColorKey, Converter={StaticResource KeyToBrush}}">
                                    <Rectangle.Width>
                                        <MultiBinding Converter="{StaticResource LocalPctToWidth}">
                                            <Binding Path="OverallMeterValue" />
                                            <Binding Path="ActualWidth" ElementName="OverallBarHost" />
                                        </MultiBinding>
                                    </Rectangle.Width>
                                </Rectangle>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- PROFIT TARGET -->
                <Border Grid.Column="2" Style="{StaticResource MeterCardStyle}" Margin="6,0"
                        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardLabelStyle}" Text="PROFIT TARGET" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ProfitTargetPercentText}"
                                       FontFamily="{StaticResource FontMono}" FontSize="30" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandBrush}" />
                            <TextBlock Text="complete" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       VerticalAlignment="Bottom" Margin="6,0,0,8" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,12"
                                   Text="{Binding ProfitTargetDescription}" />
                        <Border Height="7" CornerRadius="4"
                                Background="{DynamicResource BgRaisedBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0.5" ClipToBounds="True"
                                x:Name="ProfitBarHost">
                            <Grid HorizontalAlignment="Stretch">
                                <Rectangle HorizontalAlignment="Left" RadiusX="3" RadiusY="3"
                                           Fill="{DynamicResource BrandBrush}">
                                    <Rectangle.Width>
                                        <MultiBinding Converter="{StaticResource LocalPctToWidth}">
                                            <Binding Path="ProfitTargetProgress" />
                                            <Binding Path="ActualWidth" ElementName="ProfitBarHost" />
                                        </MultiBinding>
                                    </Rectangle.Width>
                                </Rectangle>
                            </Grid>
                        </Border>
                        <!-- Auto-close-on-target toggle: bound directly to the
                             selected account's PropConfig flag. Checking this
                             persists immediately (PropConfig is the live
                             account record). When the target is reached on
                             a subsequent tick, the engine auto-closes. -->
                        <CheckBox x:Name="AutoCloseOnTargetCheckbox"
                                  Content="Close all positions when target hits"
                                  IsChecked="{Binding SelectedAccount.Model.PropConfig.CloseAllOnTargetHit, Mode=TwoWay}"
                                  Click="OnAutoCloseOnTargetClick"
                                  FontSize="10.5"
                                  Foreground="{DynamicResource TextMutedBrush}"
                                  Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- TRADING DAYS — wires up to stats; shows "0 / N" until deal history arrives -->
                <Border Grid.Column="3" Style="{StaticResource MeterCardStyle}" Margin="6,0,0,0"
                        DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardLabelStyle}" Text="TRADING DAYS" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding MinTradingDaysText}"
                                       FontFamily="{StaticResource FontMono}" FontSize="30" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="days" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}"
                                       VerticalAlignment="Bottom" Margin="6,0,0,8" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="11.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,6,0,12"
                                   Text="Progress toward your firm's minimum trading days requirement." />
                        <Border Height="7" CornerRadius="4"
                                Background="{DynamicResource BgRaisedBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0.5" ClipToBounds="True"
                                x:Name="TradingDaysBarHost">
                            <Grid HorizontalAlignment="Stretch">
                                <Rectangle HorizontalAlignment="Left" RadiusX="3" RadiusY="3"
                                           Fill="{DynamicResource StatusOkBrush}">
                                    <Rectangle.Width>
                                        <MultiBinding Converter="{StaticResource LocalPctToWidth}">
                                            <Binding Path="TradingDaysProgress" />
                                            <Binding Path="ActualWidth" ElementName="TradingDaysBarHost" />
                                        </MultiBinding>
                                    </Rectangle.Width>
                                </Rectangle>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 3x2 DETAILS GRID -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ROW 1 COL 1: FIRM RULES -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource DetailCardStyle}"
                        Margin="0,0,6,12"
                        DataContext="{Binding SelectedAccount.Model.PropConfig}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardLabelStyle}" Text="FIRM RULES" />
                        <StackPanel>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Firm" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding FirmName}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Starting balance" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding StartingBalance, StringFormat='{}{0:N2}'}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Daily loss limit" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding DailyLossLimit, StringFormat='{}{0:N2}'}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Max overall loss" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding MaxLossLimit, StringFormat='{}{0:N2}'}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Drawdown type" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding DrawdownType}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Profit target" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding ProfitTarget, StringFormat='{}{0:N2}', TargetNullValue='—'}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Min. trading days" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding MinTradingDays, TargetNullValue='—'}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Max challenge days" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding MaxChallengePeriodDays, TargetNullValue='—'}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Consistency rule" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ConsistencyMaxDayPercent, StringFormat='{}{0}%', TargetNullValue='—'}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ROW 1 COL 2: LIVE STATE -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailCardStyle}"
                        Margin="6,0,6,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardLabelStyle}" Text="LIVE STATE" />
                        <StackPanel DataContext="{Binding SelectedAccount}">
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Current balance" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding BalanceText}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Floating P&amp;L" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding FloatingProfitText}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{Binding FloatingProfitColorKey, Converter={StaticResource KeyToBrush}}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Equity" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding EquityText}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Margin used" FontSize="12.5"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding MarginLevelText}"
                                           FontFamily="{StaticResource FontMono}" FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                        </StackPanel>

                        <!-- Reset countdown -->
                        <Border Background="{DynamicResource BgRaisedBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="14,10" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ResetCountdownText}"
                                           FontFamily="{StaticResource FontMono}"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ResetCountdownLabel}"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ROW 1 COL 3: MAX LOSS PER TRADE — meter for per-trade
                     drawdown vs the firm's per-trade cap (if configured). -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource DetailCardStyle}"
                        Margin="6,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardLabelStyle}" Text="MAX LOSS PER TRADE" />

                        <!-- Shown when this rule IS configured: live meter -->
                        <StackPanel Visibility="{Binding HasMaxLossPerTradeConfigured, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding MaxLossPerTradePercentText}"
                                           FontFamily="{StaticResource FontMono}" FontSize="28" FontWeight="SemiBold"
                                           Foreground="{Binding MaxLossPerTradeColorKey, Converter={StaticResource KeyToBrush}}" />
                                <TextBlock Text="of limit" FontSize="11"
                                           Foreground="{DynamicResource TextFaintBrush}"
                                           VerticalAlignment="Bottom" Margin="6,0,0,8" />
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="11.5"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,6,0,12"
                                       Text="{Binding MaxLossPerTradeDescription}" />
                            <Border Height="7" CornerRadius="4"
                                    Background="{DynamicResource BgRaisedBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0.5" ClipToBounds="True"
                                    x:Name="MaxPerTradeBarHost">
                                <Grid HorizontalAlignment="Stretch">
                                    <Rectangle HorizontalAlignment="Left" RadiusX="3" RadiusY="3"
                                               Fill="{Binding MaxLossPerTradeColorKey, Converter={StaticResource KeyToBrush}}">
                                        <Rectangle.Width>
                                            <MultiBinding Converter="{StaticResource LocalPctToWidth}">
                                                <Binding Path="MaxLossPerTradeProgress" />
                                                <Binding Path="ActualWidth" ElementName="MaxPerTradeBarHost" />
                                            </MultiBinding>
                                        </Rectangle.Width>
                                    </Rectangle>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Shown when not configured: helpful hint -->
                        <TextBlock Visibility="{Binding HasMaxLossPerTradeConfigured, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                   TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,4,0,0"
                                   Text="Some firms cap the loss on a single trade (e.g. 2% of account). Set 'Max loss per trade' on this account to enable a live meter that tracks the worst-bleeding open position vs the limit." />
                    </StackPanel>
                </Border>

                <!-- ROW 2 (full width): CONSISTENCY
                     Spans all 3 columns. Shows per-day P&L history (bar chart)
                     plus a status line + warning relative to the firm's
                     consistency rule (e.g. FTMO's "no day > 40% of total profit").
                     Updates live as new trades close (deal-history feed). -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                        Style="{StaticResource DetailCardStyle}"
                        Margin="0,0,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource CardLabelStyle}"
                                       Text="CONSISTENCY" Margin="0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ConsistencyHeadline}"
                                       FontFamily="{StaticResource FontMono}" FontSize="10"
                                       Foreground="{Binding ConsistencyColorKey, Converter={StaticResource KeyToBrush}}" />
                        </Grid>

                        <!-- The bar chart itself. Bound to ConsistencyBars, which
                             is a flat collection of view-models: { Date, Pnl,
                             RelativeHeightPercent, IsGain, IsBiggestDay }.
                             Each bar's vertical position is normalized so the
                             biggest absolute-value day fills the whole panel. -->
                        <Border Background="{DynamicResource BgRaisedBrush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!-- The bars. We use an ItemsControl with a
                                     UniformGrid panel so all days share width
                                     evenly across the card. Each item draws a
                                     vertical bar inside its cell, with the top
                                     of the bar at a height proportional to
                                     RelativeHeightPercent. -->
                                <ItemsControl Grid.Row="0"
                                              ItemsSource="{Binding ConsistencyBars}"
                                              Height="120">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,0" ToolTip="{Binding TooltipText}">
                                                <Grid.RowDefinitions>
                                                    <!-- Top half: positive bars grow downward from center -->
                                                    <RowDefinition Height="*" />
                                                    <!-- Center line / zero -->
                                                    <RowDefinition Height="1" />
                                                    <!-- Bottom half: negative bars grow upward from center -->
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <!-- Positive bar (anchored to bottom of top row) -->
                                                <Border Grid.Row="0"
                                                        VerticalAlignment="Bottom"
                                                        Background="{Binding ColorKey, Converter={StaticResource KeyToBrush}}"
                                                        Height="{Binding PositiveHeight}"
                                                        CornerRadius="2,2,0,0" />

                                                <!-- Zero baseline -->
                                                <Border Grid.Row="1" Background="{DynamicResource BorderSubtleBrush}" />

                                                <!-- Negative bar (anchored to top of bottom row) -->
                                                <Border Grid.Row="2"
                                                        VerticalAlignment="Top"
                                                        Background="{Binding ColorKey, Converter={StaticResource KeyToBrush}}"
                                                        Height="{Binding NegativeHeight}"
                                                        CornerRadius="0,0,2,2" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- X-axis labels: first day, middle, today -->
                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding ConsistencyFirstDayLabel}"
                                               HorizontalAlignment="Left"
                                               FontFamily="{StaticResource FontMono}" FontSize="9.5"
                                               Foreground="{DynamicResource TextFaintBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding ConsistencyMiddleLabel}"
                                               HorizontalAlignment="Center"
                                               FontFamily="{StaticResource FontMono}" FontSize="9.5"
                                               Foreground="{DynamicResource TextFaintBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding ConsistencyLastDayLabel}"
                                               HorizontalAlignment="Right"
                                               FontFamily="{StaticResource FontMono}" FontSize="9.5"
                                               Foreground="{DynamicResource TextFaintBrush}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Status / warning line. Plain-language summary so
                             traders feel cared for: what the rule is, where
                             they stand, and a recommendation. -->
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Text="{Binding ConsistencyDescription}" />
                    </StackPanel>
                </Border>

            </Grid>

            <!-- TIP STRIP -->
            <Border Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BrandBrush}"
                    BorderThickness="3,1,1,1"
                    CornerRadius="8"
                    Padding="14,12">
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}">
                    <Run Text="Reminder:" FontWeight="SemiBold" Foreground="{DynamicResource BrandBrush}" />
                    <Run Text=" Limitless tracks these limits for YOUR awareness only. Your prop firm enforces the real rules independently — always verify against your firm's official dashboard. If you enable auto-pause or auto-close in account settings, the engine will protect this account automatically when limits get close." />
                </TextBlock>
            </Border>
        </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
