<Window x:Class="LTC.App.Views.ThemeTransitionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" Height="180"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="{StaticResource FontUi}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!--
    Theme transition overlay. Sits on top of MainWindow for ~3 seconds while
    we swap the live palette brushes underneath. The user sees:
      0.0s  - Overlay fades in (current theme colors)
      1.5s  - Brush swap fires (overlay + main window flip simultaneously)
      3.0s  - Overlay fades out

    Because the overlay binds to the same theme brushes everything else uses,
    the swap also retints THIS window mid-animation — which is the desired
    effect: it visually demonstrates the transition.

    Layout: minimal centred card with the logo mark, a one-line "Switching to
    X mode" message, and a 3-second progress strip.
    -->

    <Border Background="{DynamicResource BgVoidBrush}"
            BorderBrush="{DynamicResource BorderStrongBrush}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid Margin="32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Brand mark + "switching to X" line on the same row -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <Grid Width="40" Height="22" VerticalAlignment="Center">
                    <Ellipse Width="18" Height="18"
                             Fill="{DynamicResource StatusOkBrush}"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Opacity="0.95" />
                    <Ellipse Width="18" Height="18"
                             Fill="{DynamicResource StatusErrBrush}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Opacity="0.95" />
                    <Path Fill="{DynamicResource BrandBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Data="M 20,3 A 9,9 0 0 1 20,21 A 9,9 0 0 1 20,3 Z"
                          Stretch="None" />
                </Grid>
                <TextBlock x:Name="TitleText"
                           Text="Switching theme"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0" />
            </StackPanel>

            <!-- Subtitle: which theme we're switching to -->
            <TextBlock Grid.Row="2"
                       x:Name="SubtitleText"
                       Text="Applying new palette to all surfaces"
                       FontFamily="{StaticResource FontMono}"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrandBrush}"
                       HorizontalAlignment="Center" />

            <!-- 3-second progress strip. Width animates from 0 to 240 over the
                 full window duration so the user has a visual countdown. -->
            <Grid Grid.Row="4"
                  Width="240" Height="2"
                  HorizontalAlignment="Center">
                <Border Background="{DynamicResource BorderSubtleBrush}" />
                <Border x:Name="ProgressFill"
                        Width="0"
                        Background="{DynamicResource BrandBrush}"
                        HorizontalAlignment="Left" />
            </Grid>
        </Grid>
    </Border>

    <!-- Window-loaded storyboard. Drives the progress fill from 0 to 240px
         over 3 seconds. The brush swap itself is fired from code-behind on
         a DispatcherTimer at the 1.5s midpoint. -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ProgressFill"
                                     Storyboard.TargetProperty="Width"
                                     From="0" To="240"
                                     Duration="0:0:3.0" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
